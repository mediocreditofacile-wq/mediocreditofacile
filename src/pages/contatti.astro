---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import ContactForm from '../components/ContactForm.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Contatti | Mediocredito Facile"
  description="Contattaci per una consulenza gratuita su noleggio operativo, leasing e finanziamenti per PMI. Rispondiamo entro 24 ore lavorative."
>
  <Header minimal={false} />

  <main>

    <!-- INTESTAZIONE PAGINA -->
    <section class="contatti-hero">
      <div class="contatti-hero__inner">
        <span class="contatti-hero__eyebrow">Contatti</span>
        <h1 class="contatti-hero__title">Parliamo del tuo progetto</h1>
        <p class="contatti-hero__sub">
          Compila il modulo o chiamaci direttamente. Ti ricontatteremo entro 24 ore lavorative
          per valutare insieme la soluzione più adatta alla tua azienda.
        </p>
      </div>
    </section>

    <!-- FORM + INFO -->
    <section class="contatti-body">
      <div class="contatti-body__inner">

        <!-- Colonna sinistra: form -->
        <div class="contatti-body__form">
          <ContactForm fonte="contatti" />
        </div>

        <!-- Colonna destra: info di contatto -->
        <aside class="contatti-body__info">
          <img src="/images/section-contatti.png" alt="Il nostro ufficio" class="contatti-info__image" loading="lazy" />
          <h2 class="contatti-info__title">Come raggiungerci</h2>

          <div class="contatti-info__item">
            <span class="material-icons-outlined" aria-hidden="true">phone</span>
            <div>
              <strong>Telefono</strong>
              <a href="tel:+393939957840">+39 393 995 7840</a>
            </div>
          </div>

          <div class="contatti-info__item">
            <span class="material-icons-outlined" aria-hidden="true">mail</span>
            <div>
              <strong>Email</strong>
              <a href="mailto:mediocreditofacile@gmail.com">mediocreditofacile@gmail.com</a>
            </div>
          </div>

          <div class="contatti-info__item">
            <span class="material-icons-outlined" aria-hidden="true">schedule</span>
            <div>
              <strong>Orari</strong>
              <span>Lun – Ven, 9:00 – 18:00</span>
            </div>
          </div>

          <div class="contatti-info__note">
            <p>Specializzati in <strong>noleggio operativo</strong>, leasing e finanziamenti per PMI.
            Rispondiamo entro 24 ore lavorative.</p>
          </div>
        </aside>

      </div>
    </section>

  </main>

  <Footer />
</Layout>

<style>
  /* INTESTAZIONE */
  .contatti-hero {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(26, 10, 62, 0.75)), url('/images/hero-contatti.png?v=2');
    background-size: cover;
    background-position: center;
    color: #fff;
    padding: 6rem 1.5rem 5.5rem;
    text-align: center;
  }

  .contatti-hero__inner {
    max-width: 640px;
    margin: 0 auto;
  }

  .contatti-hero__eyebrow {
    display: inline-block;
    font-size: 0.8rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .contatti-hero__title {
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    margin-bottom: 1rem;
  }

  .contatti-hero__sub {
    font-size: 1.05rem;
    line-height: 1.65;
    color: rgba(255, 255, 255, 0.85);
  }

  /* CORPO PAGINA: form + info affiancati */
  .contatti-body {
    padding: 4rem 1.5rem;
    background: var(--color-bg);
  }

  .contatti-body__inner {
    max-width: 960px;
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 340px;
    gap: 4rem;
    align-items: start;
  }

  /* Il ContactForm ha già il suo stile interno: qui rimuoviamo il padding extra */
  .contatti-body__form :global(.form-section) {
    padding: 0;
    background: transparent;
  }

  /* COLONNA INFO */
  .contatti-info__image {
    width: 100%;
    border-radius: 12px;
    object-fit: cover;
    max-height: 220px;
    margin-bottom: 1.5rem;
  }

  .contatti-body__info {
    padding-top: 0.5rem;
  }

  .contatti-info__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 1.75rem;
  }

  .contatti-info__item {
    display: flex;
    align-items: flex-start;
    gap: 0.9rem;
    margin-bottom: 1.5rem;
  }

  .contatti-info__item .material-icons-outlined {
    font-size: 1.4rem;
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 2px;
  }

  .contatti-info__item div {
    display: flex;
    flex-direction: column;
    gap: 0.2rem;
  }

  .contatti-info__item strong {
    font-size: 0.85rem;
    font-weight: 700;
    color: var(--color-primary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .contatti-info__item a,
  .contatti-info__item span {
    font-size: 1rem;
    color: var(--color-text);
    text-decoration: none;
  }

  .contatti-info__item a:hover {
    color: var(--color-primary);
    text-decoration: underline;
  }

  .contatti-info__note {
    margin-top: 2rem;
    padding: 1.25rem 1.5rem;
    background: var(--color-bg-alt);
    border-left: 3px solid var(--color-primary);
    border-radius: 0 8px 8px 0;
  }

  .contatti-info__note p {
    font-size: 0.9rem;
    color: var(--color-text-light);
    line-height: 1.6;
    margin: 0;
  }

  /* RESPONSIVE */
  @media (max-width: 768px) {
    .contatti-body__inner {
      grid-template-columns: 1fr;
      gap: 2.5rem;
    }

    .contatti-body__info {
      order: -1; /* info sopra il form su mobile */
      padding-top: 0;
    }

    .contatti-body {
      padding: 3rem 1.25rem;
    }

    .contatti-hero {
      padding: 3rem 1.25rem 2.5rem;
    }
  }
</style>
