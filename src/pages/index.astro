---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Icon from '../components/Icon.astro';

// Servizi homepage — layout asimmetrico:
// - 1 feature (Noleggio): card grande con immagine, bullets, cta dedicato
// - 2 main (Leasing, Finanziamenti): card medie a destra, impilate
// - 3 secondary (Fotovoltaico, Ristorazione, Agevolazioni): card piccole sotto
const servizioFeature = {
  icon: 'noleggio-operativo',
  slug: 'noleggio-operativo',
  title: 'Noleggio Operativo',
  tagline: 'Il modo piu intelligente di portare in azienda macchinari e tecnologia.',
  bullets: [
    'Zero anticipo, canone mensile 100% deducibile (art. 108 TUIR)',
    'Manutenzione e assicurazione incluse, nessuna sorpresa',
    'Non appare come debito in bilancio, niente Centrale Rischi',
  ],
  ctaText: 'Calcola il canone',
  ctaHref: '/tools/simulatore-noleggio-operativo',
  // Foto definitiva (Nano Banana 2K, 25 apr 2026) generata secondo
  // visual-identity-images.md: imprenditore PMI veneto al telefono mid-stride
  // nel suo capannone, scena rubata, regola dei terzi, anatomia rigorosa.
  image: '/images/feature-noleggio-operativo.webp',
  imageAlt: 'Imprenditore PMI veneto al telefono nel suo capannone, mentre attraversa il reparto produzione',
};

const serviziMain = [
  {
    icon: 'leasing-strumentale',
    slug: 'leasing-strumentale',
    title: 'Leasing Strumentale',
    desc: 'Per chi vuole il bene a libro, con il riscatto finale gia scritto in contratto.',
    bullets: [
      'Riscatto finale a condizioni negoziate',
      'Maxi-canone iniziale flessibile',
      'Beni 4.0 con iperammortamento incluso',
    ],
    ctaText: 'Scegli il leasing',
  },
  {
    icon: 'finanziamenti-pmi',
    slug: 'finanziamenti/',
    title: 'Finanziamenti PMI',
    desc: 'Liquidita per crescere o per investire. Confrontiamo gli istituti per le condizioni migliori.',
    bullets: [
      'Da 50.000 euro in su',
      '12 istituti bancari a confronto',
      'Pre-delibera in 24 ore lavorative',
    ],
    ctaText: 'Richiedi una proposta',
  },
];

const serviziSecondary = [
  {
    icon: 'fotovoltaico',
    slug: 'noleggio-fotovoltaico-zero-anticipo',
    title: 'Fotovoltaico Aziendale',
    desc: 'Impianto a canone fisso. Il risparmio in bolletta copre la rata.',
    ctaText: 'Simula il risparmio',
  },
  {
    icon: 'ristorazione',
    slug: 'noleggio-operativo-ristorazione',
    title: 'Ristorazione',
    desc: 'Cucine professionali, forni, abbattitori a canone mensile fisso.',
    ctaText: 'Vedi i canoni',
  },
  {
    icon: 'agevolazioni',
    slug: 'finanziamenti/agevolazioni',
    title: 'Agevolazioni',
    desc: 'Sabatini, Transizione 5.0, Fondo Garanzia MCC, Bando ISI: massimizziamo il vantaggio.',
    ctaText: 'Verifica idoneita',
  },
];

// Step "Come funziona"
const steps = [
  { num: '01', title: 'Parlaci del tuo progetto', desc: 'Raccontaci cosa ti serve: beni, importo, tempistiche. Una chiamata di 15 minuti è sufficiente.' },
  { num: '02', title: 'Confrontiamo le soluzioni', desc: 'Analizziamo le offerte di oltre 10 società di noleggio e leasing per trovare le condizioni migliori.' },
  { num: '03', title: 'Delibera in 48 ore', desc: 'Ti presentiamo la proposta migliore. Dalla firma alla delibera bastano 48 ore lavorative.' },
];

// Numeri
const stats = [
  { value: '10+', label: 'Società partner' },
  { value: '48h', label: 'Tempo di delibera' },
  { value: '100%', label: 'Canone deducibile' },
  { value: '€0', label: 'Anticipo richiesto' },
];

// FAQ
const faq = [
  { q: 'Qual è la differenza tra noleggio operativo e leasing?', a: 'Il noleggio operativo è un costo operativo (OPEX) che non appare come debito in bilancio e non viene segnalato in Centrale Rischi. Il leasing è un finanziamento (CAPEX) con riscatto obbligatorio. Il noleggio offre maggiore flessibilità e vantaggi fiscali immediati.' },
  { q: 'Serve un anticipo per attivare il noleggio?', a: 'No. Il noleggio operativo non richiede alcun anticipo. Si paga solo il canone periodico (mensile o trimestrale) dalla data di attivazione del contratto.' },
  { q: 'Quanto tempo serve per la delibera?', a: 'Dalla ricezione della documentazione completa, la pre-delibera arriva in 24 ore e la delibera definitiva entro 48 ore lavorative.' },
  { q: 'Il canone di noleggio è deducibile fiscalmente?', a: 'Sì, il canone di noleggio operativo è interamente deducibile dal reddito d\'impresa come costo operativo (art. 108 TUIR). È un vantaggio fiscale immediato rispetto all\'ammortamento di un bene acquistato.' },
  { q: 'Cosa succede alla fine del contratto?', a: 'A scadenza hai tre opzioni: riscattare il bene a un valore residuo concordato, rinnovare il contratto con beni aggiornati, oppure restituire il bene senza ulteriori costi.' },
];
// Structured data FAQ per rich snippets Google
const faqLD = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faq.map((f) => ({
    '@type': 'Question',
    name: f.q,
    acceptedAnswer: { '@type': 'Answer', text: f.a },
  })),
};
---

<Layout
  title="Mediocredito Facile — Noleggio Operativo, Leasing e Finanziamenti per PMI"
  description="Mediocredito Facile: accesso a 12+ società di noleggio operativo e leasing per PMI. Un unico interlocutore, la soluzione più adatta alla tua azienda. Simulatore online gratuito."
>
  <script type="application/ld+json" set:html={JSON.stringify(faqLD)} />
  <Header />
  <main>
    {/* ═══ HERO ═══ */}
    <section class="hero">
      <div class="hero__inner">
        <div class="hero__content">
          <span class="hero__badge">L'Officina del Credito</span>
          <h1 class="hero__title">
            Noleggio, Leasing e Finanziamenti<br />per la Tua Impresa
          </h1>
          <p class="hero__sub">
            Confrontiamo le migliori soluzioni finanziarie da oltre 10 società partner.
            Zero anticipo, canone fisso, delibera in 48 ore.
          </p>
          <div class="hero__actions">
            <a href="/finanza-veloce" class="hero__btn hero__btn--primary">Richiedi Preventivo</a>
            <a href="tel:+393939957840" class="hero__btn hero__btn--outline">
              <Icon name="phone" size={20} />
              Chiama Ora
            </a>
          </div>
        </div>
        <div class="hero__image">
          {/* Placeholder per foto hero — vedi prompt Midjourney */}
          <img src="/images/hero-homepage.webp" alt="Servizi finanziari per PMI — Mediocredito Facile" loading="eager" />
        </div>
      </div>
    </section>

    {/* ═══ SERVIZI — LAYOUT ASIMMETRICO ═══ */}
    <section class="servizi">
      <div class="servizi__inner">
        <h2 class="section-title">Gli strumenti dell'Officina</h2>
        <p class="section-subtitle">Un punto di accesso a piu soluzioni di credito. Sei strumenti, un solo interlocutore.</p>

        {/* Riga 1: feature Noleggio + 2 main impilate */}
        <div class="servizi__top">
          <a href={`/${servizioFeature.slug}`} class="sfeature">
            <div class="sfeature__media">
              {servizioFeature.image ? (
                <img src={servizioFeature.image} alt={servizioFeature.imageAlt} loading="lazy" />
              ) : (
                <div class="sfeature__placeholder" aria-hidden="true">
                  <Icon name="noleggio-operativo" size={64} />
                </div>
              )}
              <span class="sfeature__badge">Servizio piu richiesto</span>
            </div>
            <div class="sfeature__body">
              <div class="sfeature__icon">
                <Icon name={servizioFeature.icon} size={28} />
              </div>
              <h3 class="sfeature__title">{servizioFeature.title}</h3>
              <p class="sfeature__tagline">{servizioFeature.tagline}</p>
              <ul class="sfeature__bullets">
                {servizioFeature.bullets.map((b) => (
                  <li>
                    <Icon name="check-circle" size={18} />
                    <span>{b}</span>
                  </li>
                ))}
              </ul>
              <span class="sfeature__cta">
                {servizioFeature.ctaText}
                <Icon name="arrow-right" size={16} />
              </span>
            </div>
          </a>

          <div class="servizi__main">
            {serviziMain.map((s) => (
              <a href={`/${s.slug}`} class="smain">
                <div class="smain__icon">
                  <Icon name={s.icon} size={24} />
                </div>
                <div class="smain__body">
                  <h3 class="smain__title">{s.title}</h3>
                  <p class="smain__desc">{s.desc}</p>
                  {s.bullets && (
                    <ul class="smain__bullets">
                      {s.bullets.map((b) => (
                        <li>
                          <Icon name="check-circle" size={14} />
                          <span>{b}</span>
                        </li>
                      ))}
                    </ul>
                  )}
                  <span class="smain__cta">
                    {s.ctaText}
                    <Icon name="arrow-right" size={14} />
                  </span>
                </div>
              </a>
            ))}
          </div>
        </div>

        {/* Riga 2: 3 card secondarie compatte */}
        <div class="servizi__bottom">
          {serviziSecondary.map((s) => (
            <a href={`/${s.slug}`} class="ssecondary">
              <div class="ssecondary__icon">
                <Icon name={s.icon} size={22} />
              </div>
              <h3 class="ssecondary__title">{s.title}</h3>
              <p class="ssecondary__desc">{s.desc}</p>
              <span class="ssecondary__cta">
                {s.ctaText}
                <Icon name="arrow-right" size={14} />
              </span>
            </a>
          ))}
        </div>
      </div>
    </section>

    {/* ═══ COME FUNZIONA ═══ */}
    <section class="steps">
      <div class="steps__inner">
        <h2 class="section-title">Come Funziona</h2>
        <p class="section-subtitle">Dal primo contatto alla delibera in tre semplici passaggi</p>
        <div class="steps__grid">
          {steps.map((s) => (
            <div class="step">
              <span class="step__num">{s.num}</span>
              <h3 class="step__title">{s.title}</h3>
              <p class="step__desc">{s.desc}</p>
            </div>
          ))}
        </div>
      </div>
    </section>

    {/* ═══ NUMERI ═══ */}
    <section class="stats">
      <div class="stats__inner">
        {stats.map((s) => (
          <div class="stat">
            <span class="stat__value">{s.value}</span>
            <span class="stat__label">{s.label}</span>
          </div>
        ))}
      </div>
    </section>

    {/* ═══ FAQ ═══ */}
    <section class="faq">
      <div class="faq__inner">
        <h2 class="section-title">Domande Frequenti</h2>
        <div class="faq__list">
          {faq.map((f, i) => (
            <details class="faq__item" open={i === 0}>
              <summary class="faq__question">
                {f.q}
                <Icon name="chevron-down" class="faq__chevron" size={20} />
              </summary>
              <p class="faq__answer">{f.a}</p>
            </details>
          ))}
        </div>
      </div>
    </section>

    {/* ═══ CTA FINALE ═══ */}
    <section class="cta-final">
      <div class="cta-final__inner">
        <div class="cta-final__image">
          {/* Placeholder per foto CTA — vedi prompt Midjourney */}
          <img src="/images/consulenza-business.webp" alt="Consulenza aziendale personalizzata" loading="lazy" />
        </div>
        <div class="cta-final__content">
          <h2 class="cta-final__title">Un unico interlocutore,<br />tutte le soluzioni</h2>
          <p class="cta-final__desc">
            Non perderti tra banche e società finanziarie. Alberto ti segue dall'inizio alla fine:
            dalla valutazione alla delibera, dalla documentazione all'attivazione. Una sola persona
            di riferimento per tutta la pratica.
          </p>
          <div class="cta-final__actions">
            <a href="/finanza-veloce" class="hero__btn hero__btn--primary">Richiedi Preventivo Gratuito</a>
            <a href="/diventa-partner" class="hero__btn hero__btn--outline">Diventa Partner</a>
          </div>
        </div>
      </div>
    </section>
  </main>
  <Footer />
</Layout>

<style>
  /* ═══ Titoli di sezione riutilizzabili ═══ */
  .section-title {
    text-align: center;
    font-size: clamp(1.6rem, 3.5vw, 2.2rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .section-subtitle {
    text-align: center;
    font-size: 1.05rem;
    color: var(--color-text-light);
    margin-bottom: 3rem;
    max-width: 600px;
    margin-left: auto;
    margin-right: auto;
  }

  /* ═══ HERO ═══ */
  .hero {
    background: linear-gradient(135deg, #f8f6ff 0%, #eef0ff 50%, #f0f8ff 100%);
    padding: 3rem 1.5rem 0;
    overflow: hidden;
  }

  .hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem;
    align-items: center;
  }

  .hero__badge {
    display: inline-block;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.4rem 1rem;
    border-radius: 100px;
    margin-bottom: 1.5rem;
  }

  .hero__title {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    font-weight: 800;
    line-height: 1.15;
    letter-spacing: -0.03em;
    color: var(--color-primary-dark);
    margin-bottom: 1.25rem;
  }

  .hero__sub {
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-text);
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero__actions {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .hero__btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 1rem;
    font-weight: 700;
    padding: 0.85rem 1.75rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .hero__btn:hover {
    transform: translateY(-2px);
  }

  .hero__btn--primary {
    background: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(254, 111, 58, 0.3);
  }

  .hero__btn--primary:hover {
    background: var(--color-accent-hover);
  }

  .hero__btn--outline {
    background: #ffffff;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .hero__btn--outline:hover {
    background: var(--color-primary-bg);
  }

  .hero__image {
    display: flex;
    align-items: flex-end;
    justify-content: center;
  }

  .hero__image img {
    width: 100%;
    max-width: 500px;
    border-radius: 16px 16px 0 0;
    object-fit: cover;
  }

  /* ═══ SERVIZI — LAYOUT ASIMMETRICO ═══ */
  .servizi {
    padding: 5rem 1.5rem;
    background: var(--color-bg-alt);
  }

  .servizi__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  /* Riga 1: feature 60% + 2 main 40% impilate */
  .servizi__top {
    display: grid;
    grid-template-columns: 1.6fr 1fr;
    gap: 1.5rem;
    margin-bottom: 1.5rem;
  }

  .servizi__main {
    display: grid;
    grid-template-rows: 1fr 1fr;
    gap: 1.5rem;
  }

  /* Riga 2: 3 secondarie */
  .servizi__bottom {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* === Feature card (Noleggio Operativo) === */
  .sfeature {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 16px;
    overflow: hidden;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
  }

  .sfeature:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 32px rgba(102, 76, 205, 0.14);
    border-color: var(--color-primary-light);
  }

  .sfeature__media {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    background: var(--color-primary-bg);
  }

  .sfeature__media img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.4s ease;
  }

  .sfeature:hover .sfeature__media img {
    transform: scale(1.03);
  }

  /* Placeholder quando manca la foto definitiva */
  .sfeature__placeholder {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background:
      linear-gradient(135deg, rgba(254, 111, 58, 0.10) 0%, rgba(102, 76, 205, 0.12) 100%),
      repeating-linear-gradient(
        45deg,
        transparent 0,
        transparent 14px,
        rgba(102, 76, 205, 0.04) 14px,
        rgba(102, 76, 205, 0.04) 15px
      );
    color: var(--color-primary);
  }

  .sfeature__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-accent);
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    padding: 0.35rem 0.75rem;
    border-radius: 100px;
    backdrop-filter: blur(8px);
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.15);
  }

  .sfeature__body {
    padding: 1.75rem 1.75rem 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .sfeature__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 52px;
    height: 52px;
    border-radius: 12px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    margin-bottom: 0.25rem;
  }

  .sfeature__title {
    font-size: 1.5rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    letter-spacing: -0.02em;
    margin: 0;
  }

  .sfeature__tagline {
    font-size: 1rem;
    color: var(--color-text);
    line-height: 1.55;
    margin: 0 0 0.5rem;
  }

  .sfeature__bullets {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 1.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .sfeature__bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.6rem;
    font-size: 0.92rem;
    color: var(--color-text);
    line-height: 1.5;
  }

  .sfeature__bullets li :global(.mcf-icon) {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  .sfeature__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    align-self: flex-start;
    background: var(--color-accent);
    color: #ffffff;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.7rem 1.25rem;
    border-radius: 8px;
    transition: gap 0.2s, background 0.2s;
  }

  .sfeature:hover .sfeature__cta {
    gap: 0.7rem;
    background: var(--color-accent-hover);
  }

  /* === Card medie (Leasing, Finanziamenti) === */
  .smain {
    position: relative;
    display: flex;
    align-items: flex-start;
    gap: 1rem;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: 14px;
    padding: 1.5rem 1.5rem 1.5rem 1.6rem;
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
    box-shadow: 0 4px 14px rgba(102, 76, 205, 0.08);
    overflow: hidden;
  }

  /* Accento verticale sinistro per gerarchia visiva (alterna viola/arancio) */
  .smain::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0;
    bottom: 0;
    width: 4px;
    background: var(--color-accent);
    transition: width 0.2s;
  }

  .smain:nth-child(2)::before {
    background: var(--color-primary);
  }

  .smain:hover {
    transform: translateY(-3px);
    box-shadow: 0 12px 28px rgba(102, 76, 205, 0.14);
    border-color: var(--color-primary-light);
  }

  .smain:hover::before {
    width: 6px;
  }

  .smain__icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: 10px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
    flex-shrink: 0;
  }

  .smain__body {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    flex: 1;
  }

  .smain__title {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin: 0;
    letter-spacing: -0.01em;
  }

  .smain__desc {
    font-size: 0.88rem;
    color: var(--color-text-light);
    line-height: 1.5;
    margin: 0;
  }

  .smain__bullets {
    list-style: none;
    padding: 0;
    margin: 0.5rem 0 0.25rem;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .smain__bullets li {
    display: flex;
    align-items: flex-start;
    gap: 0.5rem;
    font-size: 0.83rem;
    color: var(--color-text);
    line-height: 1.4;
  }

  .smain__bullets li :global(.mcf-icon) {
    color: var(--color-accent);
    flex-shrink: 0;
    margin-top: 1px;
  }

  /* Su Finanziamenti (seconda card) i check sono viola */
  .smain:nth-child(2) .smain__bullets li :global(.mcf-icon) {
    color: var(--color-primary);
  }

  .smain__cta {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 0.5rem;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: gap 0.2s;
