---
/**
 * Hub strumenti gratuiti — /tools/
 * Lista dei tool disponibili per le PMI.
 */
import ToolLayout from '../../layouts/ToolLayout.astro';
import ToolCard from '../../components/tools/ToolCard.astro';
---

<ToolLayout
  title="Strumenti Gratuiti per PMI — Simulatori e Calcolatori | Mediocredito Facile"
  description="Simulatori, calcolatori e strumenti pratici per valutare noleggio operativo, leasing e finanziamenti. Gratis, senza registrazione."
>
  <section class="tools-hub">
    <div class="tools-hub__inner">
      <h1 class="tools-hub__title">Strumenti gratuiti per le PMI</h1>
      <p class="tools-hub__sub">
        Simulatori e calcolatori pratici per valutare noleggio operativo, leasing e finanziamenti.
        Gratis, senza registrazione.
      </p>

      <div class="tools-hub__grid">
        <ToolCard
          title="Simulatore Noleggio Operativo"
          description="Calcola il canone mensile, il valore di riscatto e confronta con l'acquisto diretto."
          href="/tools/simulatore-noleggio-operativo"
          icon="calculate"
        />

        <a href="/tools/marotta" class="tool-card tool-card--reserved">
          <span class="tool-card__badge">Riservato</span>
          <span class="tool-card__icon material-icons-outlined" aria-hidden="true">precision_manufacturing</span>
          <h2 class="tool-card__title">Marotta Evolution — Tool Finanziario</h2>
          <p class="tool-card__desc">Lookup P.IVA caseifici: canale finanziario, simulatore canone, funnel burrata.</p>
          <span class="tool-card__link">
            Apri il tool
            <span class="material-icons-outlined" aria-hidden="true">arrow_forward</span>
          </span>
        </a>
      </div>
    </div>
  </section>
</ToolLayout>

<style>
  .tools-hub {
    padding: 4rem 1.5rem 5rem;
  }

  .tools-hub__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .tools-hub__title {
    text-align: center;
    font-size: clamp(1.75rem, 4vw, 2.5rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.75rem;
    letter-spacing: -0.02em;
  }

  .tools-hub__sub {
    text-align: center;
    font-size: 1.05rem;
    color: var(--color-text-light);
    max-width: 600px;
    margin: 0 auto 3rem;
    line-height: 1.65;
  }

  .tools-hub__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
    gap: 2rem;
  }

  /* Card inline per Marotta (con badge) */
  .tool-card {
    display: flex;
    flex-direction: column;
    position: relative;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    padding: 2rem 1.75rem;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    transition: transform 0.2s, box-shadow 0.2s;
  }

  .tool-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(102, 76, 205, 0.1);
  }

  .tool-card__badge {
    position: absolute;
    top: 1rem;
    right: 1rem;
    background: var(--color-primary);
    color: #ffffff;
    font-size: 0.72rem;
    font-weight: 700;
    padding: 0.2rem 0.6rem;
    border-radius: 20px;
    letter-spacing: 0.03em;
    text-transform: uppercase;
  }

  .tool-card__icon {
    font-size: 2.5rem;
    color: var(--color-primary);
    margin-bottom: 1rem;
  }

  .tool-card__title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 0.6rem;
  }

  .tool-card__desc {
    font-size: 0.95rem;
    color: var(--color-text-light);
    line-height: 1.6;
    flex: 1;
  }

  .tool-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    margin-top: 1.25rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-accent);
  }

  .tool-card__link .material-icons-outlined {
    font-size: 1rem;
  }

  @media (max-width: 640px) {
    .tools-hub {
      padding: 3rem 1.25rem 4rem;
    }

    .tools-hub__grid {
      grid-template-columns: 1fr;
    }
  }
</style>
