---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

// Recupera tutti gli articoli e ordinali per data (più recente prima)
const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

// Formatta la data in italiano
function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}
---

<Layout
  title="Blog — Mediocredito Facile | Casi Studio e Guide sul Noleggio Operativo"
  description="Casi studio reali, guide pratiche e approfondimenti su noleggio operativo, leasing, finanziamenti PMI e agevolazioni fiscali per imprese italiane."
>
  <Header />
  <main>
    <section class="blog-hero">
      <div class="blog-hero__inner">
        <h1 class="blog-hero__title">Blog</h1>
        <p class="blog-hero__sub">
          Casi studio reali, guide pratiche e approfondimenti per imprenditori che vogliono
          far lavorare meglio i propri soldi.
        </p>
      </div>
    </section>

    <section class="blog-list">
      <div class="blog-list__inner">
        {posts.map((post) => (
          <a href={`/blog/${post.id}`} class="post-card">
            {post.data.image && (
              <div class="post-card__image">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card__body">
              <div class="post-card__meta">
                <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                <span class="post-card__sep">·</span>
                <span>{post.data.author}</span>
              </div>
              <h2 class="post-card__title">{post.data.title}</h2>
              <p class="post-card__desc">{post.data.description}</p>
              <div class="post-card__tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="post-card__tag">{tag}</span>
                ))}
              </div>
              <span class="post-card__link">
                Leggi l'articolo
                <span class="material-icons-outlined" aria-hidden="true">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

    <script>
      /* Rileva l'aspect ratio di ogni immagine blog e applica la classe corrispondente */
      document.querySelectorAll('.post-card__image img').forEach((img) => {
        const el = img as HTMLImageElement;
        const apply = () => {
          const ratio = el.naturalWidth / el.naturalHeight;
          const card = el.closest('.post-card');
          if (!card) return;
          if (ratio < 0.9) card.classList.add('post-card--vertical');
          else if (ratio > 1.5) card.classList.add('post-card--wide');
        };
        if (el.complete) apply();
        else el.addEventListener('load', apply);
      });
    </script>
  </main>
  <Footer />
</Layout>

<style>
  /* ═══ Hero Blog ═══ */
  .blog-hero {
    background: linear-gradient(135deg, #f8f6ff 0%, #eef0ff 50%, #f0f8ff 100%);
    padding: 4rem 1.5rem 3rem;
    text-align: center;
  }

  .blog-hero__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .blog-hero__title {
    font-size: clamp(2rem, 4.5vw, 2.8rem);
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-bottom: 0.75rem;
    letter-spacing: -0.03em;
  }

  .blog-hero__sub {
    font-size: 1.1rem;
    color: var(--color-text-light);
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  /* ═══ Lista articoli ═══ */
  .blog-list {
    padding: 3rem 1.5rem 5rem;
  }

  .blog-list__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2rem;
  }

  .post-card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    overflow: hidden;
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.04);
    transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s;
  }

  .post-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 24px rgba(102, 76, 205, 0.1);
    border-color: var(--color-primary-light);
  }

  /* Immagine verticale (3:4): card occupa due righe */
  .post-card--vertical {
    grid-row: span 2;
  }

  /* Immagine wide (16:9): card occupa due colonne */
  .post-card--wide {
    grid-column: span 2;
    flex-direction: row;
  }

  .post-card__image {
    flex-shrink: 0;
  }

  .post-card__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Default (4:3 e senza immagine): immagine sopra, testo sotto */
  .post-card:not(.post-card--wide) .post-card__image {
    height: 220px;
  }

  /* Verticale: immagine più alta */
  .post-card--vertical .post-card__image {
    height: 320px;
  }

  /* Wide: immagine a sinistra, testo a destra */
  .post-card--wide .post-card__image {
    width: 45%;
  }

  .post-card__body {
    padding: 1.75rem;
    display: flex;
    flex-direction: column;
  }

  .post-card__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.82rem;
    color: var(--color-text-light);
    margin-bottom: 0.75rem;
  }

  .post-card__sep {
    color: var(--color-border);
  }

  .post-card__title {
    font-size: 1.2rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    line-height: 1.35;
    margin-bottom: 0.6rem;
  }

  .post-card__desc {
    font-size: 0.92rem;
    color: var(--color-text-light);
    line-height: 1.6;
    flex: 1;
    margin-bottom: 1rem;
  }

  .post-card__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .post-card__tag {
    font-size: 0.75rem;
    font-weight: 600;
    padding: 0.2rem 0.6rem;
    border-radius: 100px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
  }

  .post-card__link {
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--color-accent);
    transition: gap 0.2s;
  }

  .post-card:hover .post-card__link {
    gap: 0.6rem;
  }

  .post-card__link .material-icons-outlined {
    font-size: 1rem;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 768px) {
    .blog-list__inner {
      grid-template-columns: 1fr;
    }

    .post-card--wide {
      grid-column: span 1;
      flex-direction: column;
    }

    .post-card--vertical {
      grid-row: span 1;
    }

    .post-card--wide .post-card__image {
      width: 100%;
    }
  }

  @media (max-width: 640px) {
    .blog-hero {
      padding: 3rem 1.25rem 2rem;
    }

    .blog-list {
      padding: 2rem 1.25rem 3.5rem;
    }

    .post-card__image,
    .post-card--vertical .post-card__image {
      height: 200px;
    }
  }
</style>
