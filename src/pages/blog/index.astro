---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Categorie per il filtro
const categories = [
  { id: 'tutti', label: 'Tutti', icon: 'apps' },
  { id: 'caso-studio', label: 'Casi studio', icon: 'cases' },
  { id: 'guida', label: 'Guide', icon: 'menu_book' },
  { id: 'fotovoltaico', label: 'Fotovoltaico', icon: 'solar_power' },
  { id: 'fiscalita', label: 'Fiscalità', icon: 'receipt' },
  { id: 'confronto', label: 'Confronti', icon: 'compare_arrows' },
];

// Il post più recente per l'evidenza
const featured = posts[0];
const rest = posts.slice(1);
---

<Layout
  title="Blog — Mediocredito Facile | Casi Studio e Guide sul Noleggio Operativo"
  description="Casi studio reali, guide pratiche e approfondimenti su noleggio operativo, leasing, finanziamenti PMI e agevolazioni fiscali per imprese italiane."
>
  <Header />
  <main>

    <!-- HERO -->
    <section class="blog-hero">
      <div class="blog-hero__inner">
        <span class="blog-hero__eyebrow">{posts.length} articoli pubblicati</span>
        <h1 class="blog-hero__title">Casi reali, numeri veri</h1>
        <p class="blog-hero__sub">
          Casi studio di PMI italiane, guide tecniche su noleggio operativo e leasing,
          approfondimenti fiscali. Tutto basato su pratiche vere, non teoria.
        </p>
      </div>
    </section>

    <!-- ARTICOLO IN EVIDENZA -->
    <section class="blog-featured">
      <div class="blog-featured__inner">
        <a href={`/blog/${featured.id}`} class="featured-card">
          {featured.data.image && (
            <div class="featured-card__image">
              <img src={featured.data.image} alt={featured.data.imageAlt || featured.data.title} loading="eager" />
            </div>
          )}
          <div class="featured-card__body">
            <span class="featured-card__badge">Ultimo articolo</span>
            <h2 class="featured-card__title">{featured.data.title}</h2>
            <p class="featured-card__desc">{featured.data.description}</p>
            <div class="featured-card__meta">
              <time datetime={featured.data.date}>{formatDate(featured.data.date)}</time>
              <span>·</span>
              <span>{featured.data.author}</span>
            </div>
            <span class="featured-card__link">
              Leggi l'articolo
              <span class="material-icons-outlined" aria-hidden="true">arrow_forward</span>
            </span>
          </div>
        </a>
      </div>
    </section>

    <!-- FILTRI CATEGORIE -->
    <section class="blog-filters">
      <div class="blog-filters__inner">
        {categories.map(cat => (
          <button
            class={`blog-filter ${cat.id === 'tutti' ? 'blog-filter--active' : ''}`}
            data-filter={cat.id}
          >
            <span class="material-icons-outlined blog-filter__icon">{cat.icon}</span>
            {cat.label}
          </button>
        ))}
      </div>
    </section>

    <!-- GRIGLIA ARTICOLI -->
    <section class="blog-list">
      <div class="blog-list__inner">
        {rest.map((post) => (
          <a
            href={`/blog/${post.id}`}
            class="post-card"
            data-tags={post.data.tags?.join(',') || ''}
          >
            {post.data.image && (
              <div class="post-card__image">
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="lazy" />
              </div>
            )}
            <div class="post-card__body">
              <div class="post-card__meta">
                <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
                <span class="post-card__sep">·</span>
                <span>{post.data.author}</span>
              </div>
              <h2 class="post-card__title">{post.data.title}</h2>
              <p class="post-card__desc">{post.data.description}</p>
              <div class="post-card__tags">
                {post.data.tags.slice(0, 3).map((tag) => (
                  <span class="post-card__tag">{tag}</span>
                ))}
              </div>
              <span class="post-card__link">
                Leggi l'articolo
                <span class="material-icons-outlined" aria-hidden="true">arrow_forward</span>
              </span>
            </div>
          </a>
        ))}
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<!-- Filtro client-side -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    const buttons = document.querySelectorAll('.blog-filter');
    const cards = document.querySelectorAll('.post-card');
    const filterMap: Record<string, string[]> = {
      'tutti': [],
      'caso-studio': ['caso studio'],
      'guida': ['guida', 'come funziona'],
      'fotovoltaico': ['fotovoltaico'],
      'fiscalita': ['deducibilità', 'IRES', 'IRAP', 'IVA', 'fiscalità', 'agevolazioni', 'credito d\'imposta', 'Transizione 5.0', 'Nuova Sabatini', 'conto termico'],
      'confronto': ['confronto', 'confronto società noleggio'],
    };

    buttons.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = (btn as HTMLElement).dataset.filter || 'tutti';
        buttons.forEach(b => b.classList.remove('blog-filter--active'));
        btn.classList.add('blog-filter--active');

        if (filter === 'tutti') {
          cards.forEach(c => (c as HTMLElement).style.display = '');
          return;
        }

        const keywords = filterMap[filter] || [];
        cards.forEach(card => {
          const tags = ((card as HTMLElement).dataset.tags || '').toLowerCase();
          const match = keywords.some(kw => tags.includes(kw.toLowerCase()));
          (card as HTMLElement).style.display = match ? '' : 'none';
        });
      });
    });
  });
</script>

<style>
  .blog-hero {
    background: linear-gradient(rgba(0,0,0,0.5), rgba(26,10,62,0.75)), url('/images/hero-tools.webp');
    background-size: cover; background-position: center;
    color: #fff; padding: 6rem 1.5rem 5.5rem; text-align: center;
  }
  .blog-hero__inner { max-width: 720px; margin: 0 auto; }
  .blog-hero__eyebrow { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 1rem; }
  .blog-hero__title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1.25rem; }
  .blog-hero__sub { font-size: clamp(1rem, 2.5vw, 1.15rem); line-height: 1.65; color: rgba(255,255,255,0.9); }

  /* FEATURED */
  .blog-featured { padding: 3rem 1.5rem 0; }
  .blog-featured__inner { max-width: var(--max-width); margin: 0 auto; }
  .featured-card { display: grid; grid-template-columns: 1fr 1fr; background: #fff; border: 2px solid var(--color-primary-bg); border-radius: var(--radius); overflow: hidden; box-shadow: 0 4px 16px rgba(102,76,205,0.08); transition: transform 0.2s, box-shadow 0.2s; }
  .featured-card:hover { transform: translateY(-3px); box-shadow: 0 8px 30px rgba(102,76,205,0.15); }
  .featured-card__image img { width: 100%; height: 100%; object-fit: cover; }
  .featured-card__body { padding: 2rem; display: flex; flex-direction: column; justify-content: center; }
  .featured-card__badge { display: inline-block; width: fit-content; font-size: 0.72rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.1em; background: var(--color-accent); color: #fff; padding: 0.2rem 0.6rem; border-radius: 20px; margin-bottom: 1rem; }
  .featured-card__title { font-size: 1.35rem; font-weight: 800; color: var(--color-primary); line-height: 1.3; margin-bottom: 0.75rem; }
  .featured-card__desc { font-size: 0.95rem; color: var(--color-text-light); line-height: 1.6; margin-bottom: 1rem; }
  .featured-card__meta { font-size: 0.82rem; color: var(--color-text-light); margin-bottom: 1rem; display: flex; gap: 0.4rem; }
  .featured-card__link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.9rem; font-weight: 600; color: var(--color-accent); }

  /* FILTRI */
  .blog-filters { padding: 2rem 1.5rem 0; }
  .blog-filters__inner { max-width: var(--max-width); margin: 0 auto; display: flex; gap: 0.5rem; flex-wrap: wrap; justify-content: center; }
  .blog-filter { display: inline-flex; align-items: center; gap: 0.3rem; padding: 0.5rem 1rem; border: 1px solid var(--color-border); border-radius: 100px; background: #fff; color: var(--color-text-light); font-size: 0.85rem; font-weight: 600; cursor: pointer; transition: all 0.2s; font-family: var(--font-family); }
  .blog-filter:hover { border-color: var(--color-primary); color: var(--color-primary); }
  .blog-filter--active { background: var(--color-primary); color: #fff; border-color: var(--color-primary); }
  .blog-filter__icon { font-size: 1rem; }

  /* GRIGLIA */
  .blog-list { padding: 2rem 1.5rem 5rem; }
  .blog-list__inner { max-width: var(--max-width); margin: 0 auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

  .post-card { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: transform 0.2s, box-shadow 0.2s, border-color 0.2s; }
  .post-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(102,76,205,0.1); border-color: var(--color-primary-light); }
  .post-card__image img { width: 100%; height: 180px; object-fit: cover; display: block; }
  .post-card__body { padding: 1.5rem; display: flex; flex-direction: column; flex: 1; }
  .post-card__meta { display: flex; align-items: center; gap: 0.4rem; font-size: 0.78rem; color: var(--color-text-light); margin-bottom: 0.6rem; }
  .post-card__sep { color: var(--color-border); }
  .post-card__title { font-size: 1.05rem; font-weight: 700; color: var(--color-primary-dark); line-height: 1.35; margin-bottom: 0.5rem; }
  .post-card__desc { font-size: 0.85rem; color: var(--color-text-light); line-height: 1.55; flex: 1; margin-bottom: 0.75rem; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .post-card__tags { display: flex; gap: 0.3rem; flex-wrap: wrap; margin-bottom: 0.75rem; }
  .post-card__tag { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 100px; background: var(--color-primary-bg); color: var(--color-primary); }
  .post-card__link { display: inline-flex; align-items: center; gap: 0.3rem; font-size: 0.85rem; font-weight: 600; color: var(--color-accent); transition: gap 0.2s; }
  .post-card:hover .post-card__link { gap: 0.6rem; }
  .post-card__link .material-icons-outlined { font-size: 0.9rem; }

  @media (max-width: 768px) {
    .blog-list__inner { grid-template-columns: 1fr; }
    .featured-card { grid-template-columns: 1fr; }
    .featured-card__image img { height: 220px; }
    .blog-hero { padding: 4rem 1.25rem 3.5rem; }
  }
</style>
