---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// Formatta la data in italiano
function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Structured data Article per SEO
const articleLD = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Mediocredito Facile',
    url: 'https://www.mediocreditofacile.it',
  },
  ...(post.data.image && {
    image: `https://www.mediocreditofacile.it${post.data.image}`,
  }),
  keywords: post.data.tags.join(', '),
};
---

<Layout
  title={`${post.data.title} | Mediocredito Facile`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLD)} />
  <Header />
  <main>
    <article class="article">
      {/* Hero immagine (se presente) */}
      {post.data.image && (
        <div class="article__hero">
          <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="eager" />
        </div>
      )}

      <div class="article__inner">
        {/* Meta e titolo */}
        <header class="article__header">
          <div class="article__meta">
            <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
            <span class="article__sep">·</span>
            <span>{post.data.author}</span>
          </div>
          <h1 class="article__title">{post.data.title}</h1>
          <div class="article__tags">
            {post.data.tags.map((tag) => (
              <span class="article__tag">{tag}</span>
            ))}
          </div>
        </header>

        {/* Contenuto dell'articolo */}
        <div class="article__content prose">
          <Content />
        </div>

        {/* CTA finale */}
        <div class="article__cta">
          <h3 class="article__cta-title">Vuoi capire se il noleggio operativo o il lease back possono funzionare per la tua azienda?</h3>
          <div class="article__cta-actions">
            <a href="/finanza-veloce" class="article__cta-btn article__cta-btn--primary">Richiedi una Valutazione Gratuita</a>
            <a href="tel:+393939957840" class="article__cta-btn article__cta-btn--outline">
              <span class="material-icons-outlined" aria-hidden="true">phone</span>
              Chiama Ora
            </a>
          </div>
        </div>

        {/* Link torna al blog */}
        <a href="/blog" class="article__back">
          <span class="material-icons-outlined" aria-hidden="true">arrow_back</span>
          Torna al blog
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* ═══ Hero immagine ═══ */
  .article__hero {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }

  .article__hero img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  /* ═══ Contenitore articolo ═══ */
  .article__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* ═══ Header articolo ═══ */
  .article__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .article__sep {
    color: var(--color-border);
  }

  .article__title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--color-primary-dark);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .article__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .article__tag {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
  }

  /* ═══ Contenuto (prose) ═══ */
  .article__content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article__content :global(h2) {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .article__content :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article__content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article__content :global(strong) {
    font-weight: 700;
    color: var(--color-primary-dark);
  }

  .article__content :global(em) {
    font-style: italic;
    color: var(--color-text-light);
  }

  .article__content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article__content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article__content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .article__content :global(a) {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--color-primary-bg);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s;
  }

  .article__content :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  /* ═══ CTA finale ═══ */
  .article__cta {
    background: linear-gradient(135deg, #f8f6ff 0%, #eef0ff 100%);
    border: 1px solid var(--color-primary-bg);
    border-radius: var(--radius);
    padding: 2rem;
    margin-top: 3rem;
    text-align: center;
  }

  .article__cta-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }

  .article__cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .article__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
  }

  .article__cta-btn:hover {
    transform: translateY(-2px);
  }

  .article__cta-btn--primary {
    background: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(254, 111, 58, 0.3);
  }

  .article__cta-btn--primary:hover {
    background: var(--color-accent-hover);
  }

  .article__cta-btn--outline {
    background: #ffffff;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .article__cta-btn--outline:hover {
    background: var(--color-primary-bg);
  }

  .article__cta-btn--outline .material-icons-outlined {
    font-size: 1.1rem;
  }

  /* ═══ Torna al blog ═══ */
  .article__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 2.5rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: gap 0.2s;
  }

  .article__back:hover {
    gap: 0.7rem;
  }

  .article__back .material-icons-outlined {
    font-size: 1.1rem;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 640px) {
    .article__hero img {
      height: 240px;
    }

    .article__inner {
      padding: 2rem 1.25rem 3rem;
    }

    .article__cta-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
