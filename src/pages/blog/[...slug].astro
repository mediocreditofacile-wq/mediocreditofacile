---
import Layout from '../../layouts/Layout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');

  // Calcola i 3 articoli correlati per ogni post con priorita':
  // 1. stesso cluster (se definito), ordinati per data desc
  // 2. se <3, completa con articoli che condividono almeno 2 tag
  // 3. se <3, completa con articoli piu' recenti
  function pickRelated(current: typeof posts[number]) {
    const others = posts.filter((p) => p.id !== current.id);
    const byDateDesc = (a: typeof posts[number], b: typeof posts[number]) =>
      new Date(b.data.date).getTime() - new Date(a.data.date).getTime();

    const picked: typeof posts = [];
    const pickedIds = new Set<string>();

    // 1) stesso cluster
    if (current.data.cluster) {
      const sameCluster = others
        .filter((p) => p.data.cluster === current.data.cluster)
        .sort(byDateDesc);
      for (const p of sameCluster) {
        if (picked.length >= 3) break;
        picked.push(p);
        pickedIds.add(p.id);
      }
    }

    // 2) almeno 2 tag in comune
    if (picked.length < 3) {
      const currentTags = new Set(current.data.tags);
      const sharedTags = others
        .filter((p) => !pickedIds.has(p.id))
        .map((p) => ({
          post: p,
          shared: p.data.tags.filter((t) => currentTags.has(t)).length,
        }))
        .filter((x) => x.shared >= 2)
        .sort((a, b) => b.shared - a.shared || byDateDesc(a.post, b.post));
      for (const { post: p } of sharedTags) {
        if (picked.length >= 3) break;
        picked.push(p);
        pickedIds.add(p.id);
      }
    }

    // 3) piu' recenti
    if (picked.length < 3) {
      const recents = others
        .filter((p) => !pickedIds.has(p.id))
        .sort(byDateDesc);
      for (const p of recents) {
        if (picked.length >= 3) break;
        picked.push(p);
        pickedIds.add(p.id);
      }
    }

    return picked.slice(0, 3);
  }

  return posts.map((post) => ({
    params: { slug: post.id },
    props: { post, related: pickRelated(post) },
  }));
}

const { post, related } = Astro.props;
const { Content } = await render(post);

// Prime 15-20 parole della description per le card correlate
function previewText(text: string, maxWords = 20): string {
  const words = text.split(/\s+/);
  if (words.length <= maxWords) return text;
  return words.slice(0, maxWords).join(' ') + '…';
}

// Formatta la data in italiano
function formatDate(dateStr: string): string {
  return new Date(dateStr).toLocaleDateString('it-IT', {
    day: 'numeric',
    month: 'long',
    year: 'numeric',
  });
}

// Structured data Article per SEO
const articleLD = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: post.data.title,
  description: post.data.description,
  datePublished: post.data.date,
  author: {
    '@type': 'Person',
    name: post.data.author,
  },
  publisher: {
    '@type': 'Organization',
    name: 'Mediocredito Facile',
    url: 'https://www.mediocreditofacile.it',
  },
  ...(post.data.image && {
    image: `https://www.mediocreditofacile.it${post.data.image}`,
  }),
  keywords: post.data.tags.join(', '),
};

// Structured data BreadcrumbList per rich snippet Home > Blog > Titolo
const breadcrumbLD = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    {
      '@type': 'ListItem',
      position: 1,
      name: 'Home',
      item: 'https://www.mediocreditofacile.it/',
    },
    {
      '@type': 'ListItem',
      position: 2,
      name: 'Blog',
      item: 'https://www.mediocreditofacile.it/blog/',
    },
    {
      '@type': 'ListItem',
      position: 3,
      name: post.data.title,
      item: `https://www.mediocreditofacile.it/blog/${post.id}/`,
    },
  ],
};
---

<Layout
  title={`${post.data.title} | Mediocredito Facile`}
  description={post.data.description}
  ogImage={post.data.image}
>
  <script type="application/ld+json" set:html={JSON.stringify(articleLD)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbLD)} />
  <Header />
  <main>
    <article class="article">
      {/* Hero immagine (se presente) */}
      {post.data.image && (
        <div class="article__hero">
          <img src={post.data.image} alt={post.data.imageAlt || post.data.title} loading="eager" />
        </div>
      )}

      <div class="article__inner">
        {/* Meta e titolo */}
        <header class="article__header">
          <div class="article__meta">
            <time datetime={post.data.date}>{formatDate(post.data.date)}</time>
            <span class="article__sep">·</span>
            <span>{post.data.author}</span>
          </div>
          <h1 class="article__title">{post.data.title}</h1>
          <div class="article__tags">
            {post.data.tags.map((tag) => (
              <span class="article__tag">{tag}</span>
            ))}
          </div>
        </header>

        {/* Contenuto dell'articolo */}
        <div class="article__content prose">
          <Content />
        </div>

        {/* Articoli correlati */}
        {related.length > 0 && (
          <aside class="related-posts">
            <h2 class="related-posts__title">Articoli correlati</h2>
            <div class="related-posts__grid">
              {related.map((rp) => (
                <a href={`/blog/${rp.id}/`} class="related-posts__card">
                  {rp.data.image && (
                    <div class="related-posts__image">
                      <img src={rp.data.image} alt={rp.data.imageAlt || rp.data.title} loading="lazy" />
                    </div>
                  )}
                  <div class="related-posts__body">
                    <h3 class="related-posts__card-title">{rp.data.title}</h3>
                    <p class="related-posts__preview">{previewText(rp.data.description)}</p>
                    <time class="related-posts__date" datetime={rp.data.date}>{formatDate(rp.data.date)}</time>
                  </div>
                </a>
              ))}
            </div>
          </aside>
        )}

        {/* CTA finale */}
        <div class="article__cta">
          <h3 class="article__cta-title">Vuoi capire se il noleggio operativo o il lease back possono funzionare per la tua azienda?</h3>
          <div class="article__cta-actions">
            <a href="/finanza-veloce" class="article__cta-btn article__cta-btn--primary">Richiedi una Valutazione Gratuita</a>
            <a href="tel:+393939957840" class="article__cta-btn article__cta-btn--outline">
              <span class="material-icons-outlined" aria-hidden="true">phone</span>
              Chiama Ora
            </a>
          </div>
        </div>

        {/* Link torna al blog */}
        <a href="/blog" class="article__back">
          <span class="material-icons-outlined" aria-hidden="true">arrow_back</span>
          Torna al blog
        </a>
      </div>
    </article>
  </main>
  <Footer />
</Layout>

<style>
  /* ═══ Hero immagine ═══ */
  .article__hero {
    width: 100%;
    max-height: 420px;
    overflow: hidden;
  }

  .article__hero img {
    width: 100%;
    height: 420px;
    object-fit: cover;
  }

  /* ═══ Contenitore articolo ═══ */
  .article__inner {
    max-width: 720px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }

  /* ═══ Header articolo ═══ */
  .article__header {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 1px solid var(--color-border);
  }

  .article__meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.88rem;
    color: var(--color-text-light);
    margin-bottom: 1rem;
  }

  .article__sep {
    color: var(--color-border);
  }

  .article__title {
    font-size: clamp(1.6rem, 4vw, 2.2rem);
    font-weight: 800;
    color: var(--color-primary-dark);
    line-height: 1.25;
    letter-spacing: -0.02em;
    margin-bottom: 1.25rem;
  }

  .article__tags {
    display: flex;
    gap: 0.4rem;
    flex-wrap: wrap;
  }

  .article__tag {
    font-size: 0.78rem;
    font-weight: 600;
    padding: 0.25rem 0.7rem;
    border-radius: 100px;
    background: var(--color-primary-bg);
    color: var(--color-primary);
  }

  /* ═══ Contenuto (prose) ═══ */
  .article__content {
    font-size: 1.05rem;
    line-height: 1.8;
    color: var(--color-text);
  }

  .article__content :global(h2) {
    font-size: 1.4rem;
    font-weight: 800;
    color: var(--color-primary-dark);
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    letter-spacing: -0.01em;
  }

  .article__content :global(h3) {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-top: 2rem;
    margin-bottom: 0.75rem;
  }

  .article__content :global(p) {
    margin-bottom: 1.25rem;
  }

  .article__content :global(strong) {
    font-weight: 700;
    color: var(--color-primary-dark);
  }

  .article__content :global(em) {
    font-style: italic;
    color: var(--color-text-light);
  }

  .article__content :global(hr) {
    border: none;
    border-top: 1px solid var(--color-border);
    margin: 2rem 0;
  }

  .article__content :global(ul),
  .article__content :global(ol) {
    margin-bottom: 1.25rem;
    padding-left: 1.5rem;
  }

  .article__content :global(li) {
    margin-bottom: 0.4rem;
  }

  .article__content :global(blockquote) {
    border-left: 3px solid var(--color-primary);
    padding-left: 1.25rem;
    margin: 1.5rem 0;
    color: var(--color-text-light);
    font-style: italic;
  }

  .article__content :global(a) {
    color: var(--color-primary);
    font-weight: 600;
    text-decoration: underline;
    text-decoration-color: var(--color-primary-bg);
    text-underline-offset: 2px;
    transition: text-decoration-color 0.2s;
  }

  .article__content :global(a:hover) {
    text-decoration-color: var(--color-primary);
  }

  /* ═══ CTA finale ═══ */
  .article__cta {
    background: linear-gradient(135deg, #f8f6ff 0%, #eef0ff 100%);
    border: 1px solid var(--color-primary-bg);
    border-radius: var(--radius);
    padding: 2rem;
    margin-top: 3rem;
    text-align: center;
  }

  .article__cta-title {
    font-size: 1.15rem;
    font-weight: 700;
    color: var(--color-primary-dark);
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }

  .article__cta-actions {
    display: flex;
    gap: 1rem;
    justify-content: center;
    flex-wrap: wrap;
  }

  .article__cta-btn {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-size: 0.95rem;
    font-weight: 700;
    padding: 0.75rem 1.5rem;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
  }

  .article__cta-btn:hover {
    transform: translateY(-2px);
  }

  .article__cta-btn--primary {
    background: var(--color-accent);
    color: #ffffff;
    box-shadow: 0 4px 14px rgba(254, 111, 58, 0.3);
  }

  .article__cta-btn--primary:hover {
    background: var(--color-accent-hover);
  }

  .article__cta-btn--outline {
    background: #ffffff;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .article__cta-btn--outline:hover {
    background: var(--color-primary-bg);
  }

  .article__cta-btn--outline .material-icons-outlined {
    font-size: 1.1rem;
  }

  /* ═══ Articoli correlati ═══ */
  .related-posts {
    margin-top: 3.5rem;
    padding-top: 2.5rem;
    border-top: 1px solid #E1DEE3;
  }

  .related-posts__title {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 1.35rem;
    font-weight: 800;
    color: #0F1020;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }

  .related-posts__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .related-posts__card {
    display: flex;
    flex-direction: column;
    background: #ffffff;
    border: 1px solid #E1DEE3;
    border-radius: 12px;
    padding: 20px;
    text-decoration: none;
    color: inherit;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;
  }

  .related-posts__card:hover {
    transform: translateY(-2px);
    box-shadow: 0 8px 20px rgba(15, 16, 32, 0.08);
    border-color: #664CCD;
  }

  .related-posts__image {
    width: 100%;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-radius: 8px;
    margin-bottom: 14px;
    background: #F8F7FA;
  }

  .related-posts__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .related-posts__body {
    display: flex;
    flex-direction: column;
    gap: 8px;
  }

  .related-posts__card-title {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 17px;
    font-weight: 700;
    color: #0F1020;
    line-height: 1.3;
    margin: 0;
  }

  .related-posts__preview {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 14px;
    color: #444451;
    line-height: 1.5;
    margin: 0;
  }

  .related-posts__date {
    font-family: 'Manrope', system-ui, sans-serif;
    font-size: 13px;
    color: #787782;
    margin-top: 4px;
  }

  @media (max-width: 768px) {
    .related-posts__grid {
      grid-template-columns: 1fr;
    }
  }

  /* ═══ Torna al blog ═══ */
  .article__back {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-top: 2.5rem;
    font-size: 0.92rem;
    font-weight: 600;
    color: var(--color-primary);
    transition: gap 0.2s;
  }

  .article__back:hover {
    gap: 0.7rem;
  }

  .article__back .material-icons-outlined {
    font-size: 1.1rem;
  }

  /* ═══ Responsive ═══ */
  @media (max-width: 640px) {
    .article__hero img {
      height: 240px;
    }

    .article__inner {
      padding: 2rem 1.25rem 3rem;
    }

    .article__cta-actions {
      flex-direction: column;
      align-items: center;
    }
  }
</style>
