---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<Layout
  title="Grazie per la tua richiesta | Mediocredito Facile"
  description="Abbiamo ricevuto la tua richiesta. Ti ricontatteremo entro 24 ore lavorative."
>
  <Header minimal={true} />
  <script>
    window.dataLayer = window.dataLayer || [];
    // Estrai lo slug della landing dal referrer per tracciare la provenienza del lead
    const referrer = document.referrer || '';
    let fonte = 'diretto';
    try {
      const url = new URL(referrer);
      const path = url.pathname.replace(/^\/|\/$/g, '');
      if (path) fonte = path;
      else fonte = 'homepage';
    } catch (_) {}
    window.dataLayer.push({ event: 'generate_lead' });
    window.dataLayer.push({ event: 'form_submission', fonte: fonte });
  </script>
  <main class="grazie">
    <div class="grazie__inner">
      <div class="grazie__icon">✓</div>
      <h1 class="grazie__title">Richiesta ricevuta!</h1>
      <p class="grazie__sub">Ti ricontatteremo entro 24 ore lavorative per fornirti il preventivo personalizzato.</p>
      <a href="/" class="grazie__cta">Torna alla home</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .grazie {
    min-height: 70vh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 4rem 1.5rem;
  }

  .grazie__inner {
    text-align: center;
    max-width: 480px;
  }

  .grazie__icon {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--color-primary);
    color: #fff;
    font-size: 2rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }

  .grazie__title {
    font-size: 2rem;
    font-weight: 800;
    color: var(--color-heading);
    margin-bottom: 1rem;
  }

  .grazie__sub {
    font-size: 1.1rem;
    color: var(--color-text-light);
    margin-bottom: 2rem;
    line-height: 1.6;
  }

  .grazie__cta {
    display: inline-block;
    background: var(--color-primary);
    color: #fff;
    padding: 0.875rem 2rem;
    border-radius: var(--radius);
    font-weight: 700;
    font-size: 1rem;
    transition: background 0.2s;
  }

  .grazie__cta:hover {
    background: var(--color-primary-light);
  }
</style>
