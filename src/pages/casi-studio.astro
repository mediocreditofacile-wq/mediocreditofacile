---
import Icon from '../components/Icon.astro';
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog');
const caseStudies = allPosts
  .filter(post => post.data.tags?.includes('caso studio'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

const guides = allPosts
  .filter(post => post.data.tags?.includes('guida') && !post.data.tags?.includes('caso studio'))
  .sort((a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime());

// Raggruppa case study per settore
const sectors = [
  { name: 'Energia e Fotovoltaico', icon: 'solar_power', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('fotovoltaico') || t.includes('energia') || t.includes('ESG')) },
  { name: 'Ristorazione e HORECA', icon: 'restaurant', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('ristorazione') || t.includes('HORECA') || t.includes('cucina')) },
  { name: 'Manifattura e Industria', icon: 'precision_manufacturing', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('food machinery') || t.includes('automazione') || t.includes('burrata') || t.includes('caseificio')) },
  { name: 'Edilizia e Mezzi', icon: 'construction', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('edilizia') || t.includes('mini-escavatori') || t.includes('mezzi')) },
  { name: 'Tecnologia e ICT', icon: 'computer', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('ICT') || t.includes('digital signage') || t.includes('tecnologia')) },
  { name: 'Healthcare e Farmacie', icon: 'local_pharmacy', filter: (p: any) => p.data.tags?.some((t: string) => t.includes('farmacie') || t.includes('healthcare') || t.includes('medicali')) },
];
---
<Layout
  title="Casi Studio — Noleggio Operativo e Leasing per PMI | Mediocredito Facile"
  description="Casi studio reali di PMI italiane che hanno usato il noleggio operativo e il leasing: ristorazione, fotovoltaico, manifattura, ICT, edilizia. Numeri veri, risultati misurati."
  ogImage="/images/hero-casi-studio.webp"
>
  <Header minimal={false} />
  <main>

    <!-- HERO -->
    <section class="cs-hero">
      <div class="cs-hero__inner">
        <span class="cs-hero__eyebrow">Casi studio</span>
        <h1 class="cs-hero__title">Storie vere di imprese che hanno scelto</h1>
        <p class="cs-hero__sub">
          Non teoria, non promesse. Aziende reali, numeri reali, risultati misurati.
          Ogni caso studio racconta un problema concreto e come lo abbiamo risolto.
        </p>
      </div>
    </section>

    <!-- SETTORI -->
    <section class="cs-sectors">
      <div class="cs-sectors__inner">
        <h2 class="cs-sectors__title">Per settore</h2>
        <div class="cs-sectors__grid">
          {sectors.map(sector => {
            const sectorPosts = caseStudies.filter(sector.filter);
            if (sectorPosts.length === 0) return null;
            return (
              <div class="cs-sector">
                <div class="cs-sector__header">
                  <Icon name={sector.icon} class="cs-sector__icon" />
                  <h3>{sector.name}</h3>
                  <span class="cs-sector__count">{sectorPosts.length} casi</span>
                </div>
                <ul class="cs-sector__list">
                  {sectorPosts.map(post => (
                    <li>
                      <a href={`/blog/${post.id}/`} class="cs-sector__link">
                        {post.data.title}
                        <Icon name="arrow_forward" />
                      </a>
                    </li>
                  ))}
                </ul>
              </div>
            );
          })}
        </div>
      </div>
    </section>

    <!-- TUTTI I CASI STUDIO -->
    <section class="cs-all">
      <div class="cs-all__inner">
        <h2 class="cs-all__title">Tutti i casi studio</h2>
        <div class="cs-all__grid">
          {caseStudies.map(post => (
            <a href={`/blog/${post.id}/`} class="cs-card">
              {post.data.image && (
                <img src={post.data.image} alt={post.data.imageAlt || post.data.title} class="cs-card__image" loading="lazy" />
              )}
              <div class="cs-card__content">
                <div class="cs-card__tags">
                  {post.data.tags?.slice(0, 3).map((tag: string) => (
                    <span class="cs-card__tag">{tag}</span>
                  ))}
                </div>
                <h3 class="cs-card__title">{post.data.title}</h3>
                <p class="cs-card__desc">{post.data.description}</p>
                <span class="cs-card__link">
                  Leggi il caso
                  <Icon name="arrow_forward" />
                </span>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- CTA -->
    <section class="cs-cta">
      <div class="cs-cta__inner">
        <h2 class="cs-cta__title">Il tuo caso potrebbe essere il prossimo</h2>
        <p class="cs-cta__text">
          Ogni settimana lavoriamo con PMI di settori diversi. Raccontaci la tua situazione
          e vediamo insieme se e come il noleggio operativo può funzionare per te.
        </p>
        <a href="/contatti" class="cs-cta__btn">Parliamone</a>
      </div>
    </section>

  </main>
  <Footer />
</Layout>

<style>
  .cs-hero {
    background: linear-gradient(rgba(0, 0, 0, 0.5), rgba(26, 10, 62, 0.75)), url('/images/hero-casi-studio.webp');
    background-size: cover; background-position: center; color: #fff; padding: 6rem 1.5rem 5.5rem; text-align: center;
  }
  .cs-hero__inner { max-width: 720px; margin: 0 auto; }
  .cs-hero__eyebrow { display: inline-block; font-size: 0.8rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.12em; color: var(--color-accent); margin-bottom: 1rem; }
  .cs-hero__title { font-size: clamp(2rem, 5vw, 3rem); font-weight: 800; line-height: 1.15; letter-spacing: -0.03em; margin-bottom: 1.25rem; }
  .cs-hero__sub { font-size: clamp(1rem, 2.5vw, 1.15rem); line-height: 1.65; color: rgba(255,255,255,0.9); }

  .cs-sectors { padding: 4.5rem 1.5rem; background: var(--color-bg-alt); }
  .cs-sectors__inner { max-width: var(--max-width); margin: 0 auto; }
  .cs-sectors__title { text-align: center; font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--color-primary); margin-bottom: 2.5rem; }
  .cs-sectors__grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }

  .cs-sector { background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius); padding: 1.5rem; }
  .cs-sector__header { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 1rem; padding-bottom: 0.75rem; border-bottom: 1px solid var(--color-border); }
  .cs-sector__icon { font-size: 1.5rem; color: var(--color-primary); }
  .cs-sector__header h3 { font-size: 1rem; font-weight: 700; color: var(--color-primary); flex: 1; }
  .cs-sector__count { font-size: 0.75rem; font-weight: 700; color: var(--color-accent); background: #FFF0EB; padding: 0.15rem 0.5rem; border-radius: 12px; }
  .cs-sector__list { list-style: none; display: flex; flex-direction: column; gap: 0.5rem; }
  .cs-sector__link { display: flex; align-items: center; justify-content: space-between; font-size: 0.9rem; color: var(--color-text); padding: 0.5rem; border-radius: 6px; transition: background 0.2s; }
  .cs-sector__link:hover { background: var(--color-bg-alt); }
  .cs-sector__link .mcf-icon { font-size: 0.9rem; color: var(--color-accent); opacity: 0; transition: opacity 0.2s; }
  .cs-sector__link:hover .mcf-icon { opacity: 1; }

  .cs-all { padding: 4.5rem 1.5rem; }
  .cs-all__inner { max-width: var(--max-width); margin: 0 auto; }
  .cs-all__title { text-align: center; font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--color-primary); margin-bottom: 2.5rem; }
  .cs-all__grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 2rem; }

  .cs-card { display: flex; flex-direction: column; background: #fff; border: 1px solid var(--color-border); border-radius: var(--radius); overflow: hidden; box-shadow: 0 2px 8px rgba(0,0,0,0.04); transition: transform 0.2s, box-shadow 0.2s; }
  .cs-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(102,76,205,0.1); }
  .cs-card__image { width: 100%; height: 180px; object-fit: cover; }
  .cs-card__content { padding: 1.5rem; flex: 1; display: flex; flex-direction: column; }
  .cs-card__tags { display: flex; flex-wrap: wrap; gap: 0.3rem; margin-bottom: 0.75rem; }
  .cs-card__tag { font-size: 0.7rem; font-weight: 600; padding: 0.15rem 0.5rem; border-radius: 100px; background: var(--color-primary-bg); color: var(--color-primary); }
  .cs-card__title { font-size: 1rem; font-weight: 700; color: var(--color-primary); margin-bottom: 0.5rem; line-height: 1.35; }
  .cs-card__desc { font-size: 0.85rem; color: var(--color-text-light); line-height: 1.55; flex: 1; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden; }
  .cs-card__link { display: inline-flex; align-items: center; gap: 0.3rem; margin-top: 1rem; font-size: 0.85rem; font-weight: 600; color: var(--color-accent); }
  .cs-card__link .mcf-icon { font-size: 0.9rem; }

  .cs-cta { padding: 4.5rem 1.5rem; background: var(--color-bg-alt); text-align: center; }
  .cs-cta__inner { max-width: 600px; margin: 0 auto; }
  .cs-cta__title { font-size: clamp(1.5rem, 3.5vw, 2rem); font-weight: 800; color: var(--color-primary); margin-bottom: 1rem; }
  .cs-cta__text { font-size: 1.05rem; color: var(--color-text); line-height: 1.65; margin-bottom: 2rem; }
  .cs-cta__btn { display: inline-flex; background: var(--color-accent); color: #fff; font-weight: 700; font-size: 1.05rem; padding: 0.9rem 2rem; border-radius: 8px; transition: background 0.2s, transform 0.15s; }
  .cs-cta__btn:hover { background: var(--color-accent-hover); transform: translateY(-1px); }

  @media (max-width: 768px) {
    .cs-hero { padding: 4rem 1.25rem 3.5rem; }
    .cs-sectors__grid { grid-template-columns: 1fr; }
    .cs-all__grid { grid-template-columns: 1fr; }
  }
</style>
