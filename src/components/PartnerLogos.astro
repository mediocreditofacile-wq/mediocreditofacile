---
// Fascione loghi partner — scorrimento continuo
// Per aggiungere/rimuovere un partner: modificare l'array qui sotto
// I file logo vanno in public/images/partners/ (PNG o SVG, sfondo trasparente)
// Affida sempre visibile, inserito ogni 2 partner
const affida = { name: 'Affida', logo: '/images/partners/affida.png', highlight: true };
const otherPartners = [
  { name: 'Grenke', logo: '/images/partners/grenke.png' },
  { name: 'Pagarent', logo: '/images/partners/pagarent.png' },
  { name: 'PEAC Solutions', logo: '/images/partners/peac.png' },
  { name: 'DLL', logo: '/images/partners/dll.png' },
  { name: 'Banca IFIS', logo: '/images/partners/ifis.svg' },
  { name: 'IFIS Rental Services', logo: '/images/partners/rental-service.svg' },
  { name: 'BCC', logo: '/images/partners/bcc.png' },
  { name: 'Compass', logo: '/images/partners/compass.png' },
  { name: 'Agos', logo: '/images/partners/agos.svg' },
  { name: 'Compara Semplice', logo: '/images/partners/compara-semplice.svg' },
];

// Inserisce Affida ogni 2 partner
const partners: Array<{name: string; logo: string; highlight?: boolean}> = [];
for (let i = 0; i < otherPartners.length; i++) {
  partners.push(otherPartners[i]);
  if ((i + 1) % 2 === 0) {
    partners.push(affida);
  }
}
// Se restano partner dispari, aggiungi Affida alla fine
if (otherPartners.length % 2 !== 0) {
  partners.push(affida);
}
---

<section class="partners">
  <p class="partners__label">Le nostre società partner</p>
  <div class="partners__track">
    <div class="partners__slide">
      {partners.map((p) => (
        <img src={p.logo} alt={p.name} class:list={['partners__logo', { 'partners__logo--highlight': p.highlight }]} loading="lazy" />
      ))}
      {partners.map((p) => (
        <img src={p.logo} alt={p.name} class:list={['partners__logo', { 'partners__logo--highlight': p.highlight }]} loading="lazy" />
      ))}
    </div>
  </div>
</section>

<style>
  .partners {
    padding: 2rem 1.5rem;
    background: var(--color-bg-alt, #f5fbff);
    text-align: center;
    overflow: hidden;
  }
  .partners__label {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-text-light, #64748b);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }
  .partners__track {
    max-width: var(--max-width, 1120px);
    margin: 0 auto;
    overflow: hidden;
    mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
    -webkit-mask-image: linear-gradient(to right, transparent 0%, black 10%, black 90%, transparent 100%);
  }
  .partners__slide {
    display: flex;
    align-items: center;
    gap: 3rem;
    animation: scroll-logos 40s linear infinite;
    width: max-content;
  }
  .partners__logo {
    height: 40px;
    width: auto;
    max-width: 140px;
    object-fit: contain;
    filter: grayscale(100%);
    opacity: 0.6;
    transition: filter 0.3s, opacity 0.3s;
    flex-shrink: 0;
  }
  .partners__logo:hover {
    filter: grayscale(0%);
    opacity: 1;
  }
  .partners__logo--highlight {
    filter: grayscale(0%) !important;
    opacity: 1 !important;
    height: 46px;
  }
  @keyframes scroll-logos {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }
  .partners__track:hover .partners__slide {
    animation-play-state: paused;
  }
  @media (max-width: 640px) {
    .partners {
      padding: 1.5rem 1rem;
    }
    .partners__logo {
      height: 32px;
      max-width: 110px;
    }
    .partners__slide {
      gap: 2rem;
    }
  }
</style>
