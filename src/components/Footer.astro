---
import PartnerLogos from './PartnerLogos.astro';
import Logo from './Logo.astro';
---

<PartnerLogos />
<footer class="footer">
  <div class="footer__inner">
    <div class="footer__brand">
      <Logo variant="inline" dark={true} height={24} />
    </div>

    <div class="footer__nav">
      <a href="/chi-siamo">Chi Siamo</a>
      <span class="footer__sep">|</span>
      <a href="/partner">Le Nostre Società</a>
      <span class="footer__sep">|</span>
      <a href="/casi-studio">Casi Studio</a>
      <span class="footer__sep">|</span>
      <a href="/blog">Blog</a>
      <span class="footer__sep">|</span>
      <a href="/faq">FAQ</a>
      <span class="footer__sep">|</span>
      <a href="/contatti">Contatti</a>
    </div>

    <div class="footer__links">
      <a href="/privacy">Privacy Policy</a>
      <span class="footer__sep">|</span>
      <a href="https://www.affida.credit/pagine/trasparenza" target="_blank" rel="noopener">Trasparenza</a>
      <span class="footer__sep">|</span>
      <a href="tel:+393939957840">+39 393 995 7840</a>
      <span class="footer__sep">|</span>
      <a href="mailto:mediocreditofacile@gmail.com">mediocreditofacile@gmail.com</a>
    </div>

    <div class="footer__legal">
      <p>Collaboratore del Mediatore Affida. Autorizzazione ad Operare — Iscrizione OAM M325</p>
      <p>Messaggio pubblicitario con finalità promozionale.</p>
      <p>Per le condizioni contrattuali del servizio di mediazione creditizia, si fa riferimento al <a href="https://www.affida.credit/pagine/trasparenza" target="_blank" rel="noopener">Foglio Informativo di Affida</a>, consultabile sul sito.</p>
    </div>

    <p class="footer__copy">
      &copy; {new Date().getFullYear()} Mediocredito Facile &mdash; Tutti i diritti riservati.
    </p>
  </div>
</footer>

<style>
  .footer {
    background: #0F1020;
    color: rgba(255, 255, 255, 0.7);
    padding: 3rem 1.5rem 2rem;
    text-align: center;
    font-size: 0.85rem;
    line-height: 1.6;
  }

  .footer__inner {
    max-width: var(--max-width);
    margin: 0 auto;
  }

  .footer__brand {
    margin-bottom: 1.25rem;
    display: flex;
    justify-content: center;
  }

  .footer__nav {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-bottom: 1rem;
  }

  .footer__nav a {
    color: rgba(255, 255, 255, 0.85);
    font-weight: 500;
    transition: color 0.2s;
  }

  .footer__nav a:hover {
    color: var(--color-accent);
  }

  .footer__links {
    display: flex;
    justify-content: center;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
    margin-bottom: 1.5rem;
  }

  .footer__links a {
    color: rgba(255, 255, 255, 0.85);
    transition: color 0.2s;
  }

  .footer__links a:hover {
    color: var(--color-accent);
  }

  .footer__sep {
    color: rgba(255, 255, 255, 0.3);
  }

  .footer__legal {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 1.25rem;
    margin-bottom: 1.25rem;
    color: rgba(255, 255, 255, 0.5);
    font-size: 0.8rem;
  }

  .footer__legal p {
    margin-bottom: 0.3rem;
  }

  .footer__legal a {
    color: rgba(255, 255, 255, 0.6);
    text-decoration: underline;
    transition: color 0.2s;
  }

  .footer__legal a:hover {
    color: var(--color-accent);
  }

  .footer__copy {
    color: rgba(255, 255, 255, 0.4);
    font-size: 0.78rem;
  }

  @media (max-width: 640px) {
    .footer {
      padding: 2.5rem 1.25rem 1.5rem;
    }

    .footer__links {
      flex-direction: column;
      gap: 0.4rem;
    }

    .footer__sep {
      display: none;
    }
  }
</style>
