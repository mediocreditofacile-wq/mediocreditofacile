---
// Componente Icon centralizzato MCF.
// Renderizza un'icona Lucide come SVG inline, colorata via currentColor.
// Uso: <Icon name="noleggio-operativo" size={32} color="var(--mcf-primary)" />

import { iconsMap, resolveIconName } from '../data/icons';

interface Props {
  name: string;
  size?: number | string;
  color?: string;
  strokeWidth?: number;
  class?: string;
  ariaLabel?: string;
}

const {
  name,
  size = '1em',
  color = 'currentColor',
  strokeWidth = 1.75,
  class: className = '',
  ariaLabel,
} = Astro.props;

const resolved = resolveIconName(name);
const svg = iconsMap[resolved];
if (!svg) {
  throw new Error(`[Icon] Nome "${name}" non risolto. Aggiungilo a src/data/icons.ts (slug, atomicIcons o materialAliases).`);
}

const sizeValue = typeof size === 'number' ? `${size}px` : size;
const inlineStyle = `color:${color};width:${sizeValue};height:${sizeValue};--icon-stroke:${strokeWidth};`;
---

<span
  class={`mcf-icon ${className}`}
  style={inlineStyle}
  role={ariaLabel ? 'img' : undefined}
  aria-label={ariaLabel}
  aria-hidden={ariaLabel ? undefined : 'true'}
  set:html={svg}
></span>

<style>
  .mcf-icon {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    line-height: 0;
    flex-shrink: 0;
  }
  .mcf-icon :global(svg) {
    width: 100%;
    height: 100%;
    stroke: currentColor;
    stroke-width: var(--icon-stroke, 1.75);
    fill: none;
  }
</style>
