---
/**
 * Logo MCF — wordmark tipografico "Mediocredito Facile"
 * "Mediocredito" è una parola unica (Medio+credito senza spazi)
 * Varianti: principale (2 righe + claim), compatto (2 righe), inline (1 riga)
 * Props dark per sfondo scuro
 */
interface Props {
  variant?: 'principale' | 'compatto' | 'inline';
  dark?: boolean;
  height?: number;
}

const { variant = 'compatto', dark = false, height = 36 } = Astro.props;
const creditoFill = dark ? '#FFFFFF' : '#293C5B';
const claimFill = dark ? '#E1DEE3' : '#664CCD';
---

{variant === 'principale' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 500 160" height={height * 2.5} class="logo logo--principale" aria-label="Mediocredito Facile — L'officina del credito">
    <text y="56" font-family="Manrope, sans-serif" font-size="50" letter-spacing="-2"><tspan font-weight="700" fill="#664CCD">Medio</tspan><tspan font-weight="300" fill={creditoFill}>credito</tspan></text>
    <text x="160" y="110" font-family="Manrope, sans-serif" font-weight="800" font-size="50" fill="#FE6F3A" letter-spacing="-1.5">Facile</text>
    <rect x="0" y="128" width="3" height="22" rx="1.5" fill="#FE6F3A"/>
    <text x="14" y="144" font-family="Manrope, sans-serif" font-weight="400" font-size="12.5" fill={claimFill} letter-spacing="3.5">L'OFFICINA DEL CREDITO</text>
  </svg>
)}

{variant === 'compatto' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 420 100" height={height * 1.8} class="logo logo--compatto" aria-label="Mediocredito Facile">
    <text y="44" font-family="Manrope, sans-serif" font-size="42" letter-spacing="-1.5"><tspan font-weight="700" fill="#664CCD">Medio</tspan><tspan font-weight="300" fill={creditoFill}>credito</tspan></text>
    <text x="130" y="90" font-family="Manrope, sans-serif" font-weight="800" font-size="42" fill="#FE6F3A" letter-spacing="-1.5">Facile</text>
  </svg>
)}

{variant === 'inline' && (
  <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 360 32" height={height} class="logo logo--inline" aria-label="Mediocredito Facile">
    <text y="26" font-family="Manrope, sans-serif" font-size="28" letter-spacing="-1"><tspan font-weight="700" fill="#664CCD">Medio</tspan><tspan font-weight="300" fill={creditoFill}>credito</tspan><tspan dx="8" font-weight="800" fill="#FE6F3A">Facile</tspan></text>
  </svg>
)}

<style>
  .logo {
    display: block;
    width: auto;
  }
</style>
