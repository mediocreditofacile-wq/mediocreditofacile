---
interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

const basePath = '/bozza-imc';
const navLinks = [
  { label: 'Home', href: basePath },
  { label: 'Finanziamenti', href: `${basePath}/finanziamenti-pmi` },
  { label: 'Agevolazioni', href: `${basePath}/bandi-agevolazioni` },
  { label: 'Chi Siamo', href: `${basePath}#chi-siamo` },
  { label: 'Contatti', href: `${basePath}#contatti` },
];
---

<header class="imc-header">
  <div class="imc-header__inner">
    <a href={basePath} class="imc-header__logo" aria-label="IMC Finanziamenti — Home">
      <span class="imc-header__logo-imc">IMC</span><span class="imc-header__logo-fin">FINANZIAMENTI</span>
    </a>

    {minimal ? (
      <a href="tel:+39" class="imc-header__phone">
        <span class="material-icons-outlined" aria-hidden="true">phone</span>
        Chiedi Informazioni
      </a>
    ) : (
      <>
        <nav class="imc-header__nav" id="imc-main-nav" aria-label="Navigazione principale">
          {navLinks.map((link) => (
            <a href={link.href} class="imc-header__nav-link">{link.label}</a>
          ))}
        </nav>

        <div class="imc-header__actions">
          <a href={`${basePath}#contatti`} class="imc-header__cta">Richiedi Valutazione</a>
        </div>

        <button class="imc-header__hamburger" id="imc-hamburger-btn" aria-label="Apri menu" aria-expanded="false" aria-controls="imc-mobile-menu">
          <span class="imc-header__hamburger-line"></span>
          <span class="imc-header__hamburger-line"></span>
          <span class="imc-header__hamburger-line"></span>
        </button>
      </>
    )}
  </div>

  {!minimal && (
    <div class="imc-header__mobile-menu" id="imc-mobile-menu" aria-hidden="true">
      <nav class="imc-header__mobile-nav">
        {navLinks.map((link) => (
          <a href={link.href} class="imc-header__mobile-link">{link.label}</a>
        ))}
        <div class="imc-header__mobile-actions">
          <a href={`${basePath}#contatti`} class="imc-header__cta">Richiedi Valutazione</a>
        </div>
      </nav>
    </div>
  )}
</header>

<script>
  const btn = document.getElementById('imc-hamburger-btn');
  const menu = document.getElementById('imc-mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.classList.toggle('open');
    menu?.classList.toggle('open');
    menu?.setAttribute('aria-hidden', String(expanded));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>

<style>
  .imc-header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(12px);
  }

  .imc-header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.85rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  .imc-header__logo {
    flex-shrink: 0;
    display: flex;
    align-items: baseline;
    gap: 0.15em;
    font-size: 1.2rem;
    letter-spacing: 0.04em;
    white-space: nowrap;
  }

  .imc-header__logo-imc {
    font-weight: 800;
    color: var(--color-primary);
  }

  .imc-header__logo-fin {
    font-weight: 800;
    color: var(--color-accent);
  }

  .imc-header__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    transition: color 0.2s;
  }

  .imc-header__phone:hover {
    color: var(--color-accent);
  }

  .imc-header__phone .material-icons-outlined {
    font-size: 1.2rem;
  }

  .imc-header__nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: center;
  }

  .imc-header__nav-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    transition: color 0.2s;
    position: relative;
  }

  .imc-header__nav-link::after {
    content: '';
    position: absolute;
    bottom: -4px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-primary);
    transition: width 0.25s ease;
  }

  .imc-header__nav-link:hover {
    color: var(--color-primary);
  }

  .imc-header__nav-link:hover::after {
    width: 100%;
  }

  .imc-header__actions {
    display: flex;
    align-items: center;
    flex-shrink: 0;
  }

  .imc-header__cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.6rem 1.25rem;
    border-radius: 8px;
    white-space: nowrap;
    background: var(--color-accent);
    color: #ffffff;
    transition: background 0.2s, transform 0.15s;
  }

  .imc-header__cta:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .imc-header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    flex-shrink: 0;
  }

  .imc-header__hamburger-line {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--color-heading);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .imc-header__hamburger.open .imc-header__hamburger-line:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }

  .imc-header__hamburger.open .imc-header__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .imc-header__hamburger.open .imc-header__hamburger-line:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  .imc-header__mobile-menu {
    display: none;
    background: #ffffff;
    border-top: 1px solid var(--color-border);
  }

  .imc-header__mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.25rem;
  }

  .imc-header__mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s;
  }

  .imc-header__mobile-link:hover {
    color: var(--color-primary);
  }

  .imc-header__mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .imc-header__mobile-actions .imc-header__cta {
    justify-content: center;
    font-size: 0.95rem;
    padding: 0.8rem 1.25rem;
  }

  @media (max-width: 960px) {
    .imc-header__nav,
    .imc-header__actions {
      display: none;
    }

    .imc-header__hamburger {
      display: flex;
      margin-left: auto;
    }

    .imc-header__mobile-menu.open {
      display: block;
    }
  }
</style>
