---
interface Props {
  fonte?: string;
  heading?: string;
  subheading?: string;
  ctaText?: string;
  variant?: 'primary' | 'secondary';
  endpoint?: string;
  redirectOnSuccess?: string;
}
const {
  fonte,
  heading = 'Richiedi Preventivo Gratuito',
  subheading = 'Compila il modulo e ti ricontatteremo entro 24 ore lavorative. Nessun impegno.',
  ctaText = 'Richiedi Preventivo Gratuito',
  variant = 'primary',
  endpoint = '/api/submit',
  redirectOnSuccess = '/grazie',
} = Astro.props;
const sectionId = variant === 'primary' ? 'contatti' : undefined;
---

<section class="form-section" id={sectionId}>
  <div class="form-section__inner">
    <h2 class="form-section__heading">{heading}</h2>
    <p class="form-section__sub">{subheading}</p>
    <form
      class="contact-form"
      action={endpoint}
      method="POST"
      data-redirect={redirectOnSuccess}
    >
      <input name="website" type="text" tabindex="-1" autocomplete="off" style="position:absolute;opacity:0;pointer-events:none;height:0;overflow:hidden" aria-hidden="true" />
      {fonte && <input type="hidden" name="fonte" value={fonte} />}
      <input type="hidden" name="variante" value={variant} />
      <div class="contact-form__field">
        <label>Nome e Cognome
          <input
            type="text"
            name="nome"
            placeholder="Mario Rossi"
            required
            autocomplete="name"
          />
        </label>
      </div>
      <div class="contact-form__field">
        <label>Email
          <input
            type="email"
            name="email"
            placeholder="mario@azienda.it"
            required
            autocomplete="email"
          />
        </label>
      </div>
      <div class="contact-form__field">
        <label>Cellulare
          <input
            type="tel"
            name="telefono"
            placeholder="+39 333 123 4567"
            required
            autocomplete="tel"
          />
        </label>
      </div>
      <button type="submit" class="contact-form__submit">
        {ctaText} ➤
      </button>
      <p class="contact-form__privacy">
        Inviando il modulo accetti la nostra
        <a href="/privacy">informativa sulla privacy</a>.
      </p>
    </form>
  </div>
</section>

<style>
  .form-section {
    padding: 4.5rem 1.5rem;
    background: var(--color-bg);
  }

  .form-section__inner {
    max-width: 520px;
    margin: 0 auto;
  }

  .form-section__heading {
    text-align: center;
    font-size: clamp(1.5rem, 3.5vw, 2rem);
    font-weight: 800;
    color: var(--color-primary);
    margin-bottom: 0.6rem;
    letter-spacing: -0.02em;
  }

  .form-section__sub {
    text-align: center;
    color: var(--color-text-light);
    margin-bottom: 2.5rem;
    font-size: 1rem;
  }

  .contact-form {
    display: flex;
    flex-direction: column;
    gap: 1.25rem;
  }

  .contact-form__field label {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-primary);
    margin-bottom: 0.35rem;
  }

  .contact-form__field input {
    width: 100%;
    padding: 0.8rem 1rem;
    border: 1.5px solid var(--color-border);
    border-radius: 8px;
    font-family: var(--font-family);
    font-size: 1rem;
    color: var(--color-text);
    background: var(--color-bg-alt);
    transition: border-color 0.2s, box-shadow 0.2s;
    margin-top: 0.35rem;
  }

  .contact-form__field input::placeholder {
    color: #94a3b8;
  }

  .contact-form__field input:focus {
    outline: none;
    border-color: var(--color-primary);
    box-shadow: 0 0 0 3px rgba(102, 76, 205, 0.15);
  }

  .contact-form__submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    background: var(--color-accent);
    color: #ffffff;
    font-family: var(--font-family);
    font-weight: 700;
    font-size: 1.05rem;
    padding: 0.9rem 2rem;
    border: none;
    border-radius: 8px;
    cursor: pointer;
    transition: background 0.2s, transform 0.15s;
    margin-top: 0.5rem;
  }

  .contact-form__submit:hover {
    background: var(--color-accent-hover);
    transform: translateY(-1px);
  }

  .contact-form__submit:disabled {
    opacity: 0.7;
    cursor: wait;
    transform: none;
  }

  .contact-form__privacy {
    text-align: center;
    font-size: 0.8rem;
    color: var(--color-text-light);
    margin-top: 0.25rem;
  }

  .contact-form__privacy a {
    color: var(--color-primary);
    text-decoration: underline;
  }

  @media (max-width: 640px) {
    .form-section {
      padding: 3rem 1.25rem;
    }
  }
</style>

<script>
  // Inizializza tutti i form di contatto presenti in pagina (supporta form intermedio + finale)
  const forms = document.querySelectorAll<HTMLFormElement>('.contact-form');
  forms.forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const btn = form.querySelector<HTMLButtonElement>('button[type="submit"]');
      const originalLabel = btn?.textContent ?? '';
      if (btn) {
        btn.disabled = true;
        btn.textContent = 'Invio in corso…';
      }
      // Endpoint e redirect sono configurabili via prop del componente Astro
      const endpoint = form.getAttribute('action') || '/api/submit';
      const redirect = form.dataset.redirect || '/grazie';
      try {
        await fetch(endpoint, { method: 'POST', body: new FormData(form) });
      } catch (_) {}
      window.location.href = redirect;
      // Fallback di ripristino nel caso il redirect tardi
      setTimeout(() => {
        if (btn) {
          btn.disabled = false;
          btn.textContent = originalLabel;
        }
      }, 5000);
    });
  });
</script>
