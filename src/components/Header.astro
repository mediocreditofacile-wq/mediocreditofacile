---
import Logo from './Logo.astro';

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;

const serviceLinks = [
  { label: 'Noleggio Operativo', href: '/noleggio-operativo' },
  { label: 'Leasing Strumentale', href: '/leasing-strumentale' },
  { label: 'Finanziamenti PMI', href: '/finanziamenti-pmi' },
  { label: 'Agevolazioni Fiscali', href: '/agevolazioni-fiscali' },
];

const navLinks = [
  { label: 'Strumenti', href: '/tools' },
  { label: 'Blog', href: '/blog' },
  { label: 'Chi Siamo', href: '/chi-siamo' },
  { label: 'Contatti', href: '/contatti' },
];
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="mediocredito facile — Home">
      <Logo variant="inline" height={28} />
    </a>

    {minimal ? (
      <a href="tel:+393939957840" class="header__phone">
        <span class="material-icons-outlined" aria-hidden="true">phone</span>
        +39 393 995 7840
      </a>
    ) : (
      <>
        <nav class="header__nav" id="main-nav" aria-label="Navigazione principale">
          <!-- Dropdown Servizi -->
          <div class="header__dropdown" id="services-dropdown">
            <button class="header__nav-link header__dropdown-trigger" aria-expanded="false" aria-haspopup="true">
              Servizi
              <span class="material-icons-outlined header__dropdown-arrow">expand_more</span>
            </button>
            <div class="header__dropdown-menu">
              {serviceLinks.map((link) => (
                <a href={link.href} class="header__dropdown-item">{link.label}</a>
              ))}
            </div>
          </div>

          {navLinks.map((link) => (
            <a href={link.href} class="header__nav-link">{link.label}</a>
          ))}
        </nav>

        <div class="header__actions">
          <a href="/diventa-partner" class="header__cta header__cta--accent">Diventa Partner</a>
        </div>

        <button class="header__hamburger" id="hamburger-btn" aria-label="Apri menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="header__hamburger-line"></span>
          <span class="header__hamburger-line"></span>
          <span class="header__hamburger-line"></span>
        </button>
      </>
    )}
  </div>

  {!minimal && (
    <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
      <nav class="header__mobile-nav">
        <!-- Servizi espandibili -->
        <button class="header__mobile-section" id="mobile-services-btn">
          Servizi
          <span class="material-icons-outlined">expand_more</span>
        </button>
        <div class="header__mobile-sub" id="mobile-services-sub">
          {serviceLinks.map((link) => (
            <a href={link.href} class="header__mobile-sublink">{link.label}</a>
          ))}
        </div>

        {navLinks.map((link) => (
          <a href={link.href} class="header__mobile-link">{link.label}</a>
        ))}
        <div class="header__mobile-actions">
          <a href="/diventa-partner" class="header__cta header__cta--accent">Diventa Partner</a>
        </div>
      </nav>
    </div>
  )}
</header>

<script>
  // Hamburger menu
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.classList.toggle('open');
    menu?.classList.toggle('open');
    menu?.setAttribute('aria-hidden', String(expanded));
  });

  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
    });
  });

  // Desktop dropdown Servizi
  const dropdown = document.getElementById('services-dropdown');
  const trigger = dropdown?.querySelector('.header__dropdown-trigger');

  trigger?.addEventListener('click', (e) => {
    e.stopPropagation();
    const expanded = trigger.getAttribute('aria-expanded') === 'true';
    trigger.setAttribute('aria-expanded', String(!expanded));
    dropdown?.classList.toggle('open');
  });

  document.addEventListener('click', () => {
    trigger?.setAttribute('aria-expanded', 'false');
    dropdown?.classList.remove('open');
  });

  dropdown?.addEventListener('click', (e) => e.stopPropagation());

  // Mobile servizi espandibili
  const mobileBtn = document.getElementById('mobile-services-btn');
  const mobileSub = document.getElementById('mobile-services-sub');

  mobileBtn?.addEventListener('click', () => {
    mobileBtn.classList.toggle('open');
    mobileSub?.classList.toggle('open');
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.97);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(10px);
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 2rem;
  }

  .header__logo { flex-shrink: 0; }

  /* Phone (minimal) */
  .header__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    transition: color 0.2s;
  }
  .header__phone:hover { color: var(--color-accent); }
  .header__phone .material-icons-outlined { font-size: 1.2rem; }

  /* Nav */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 1.5rem;
    flex: 1;
    justify-content: center;
  }

  .header__nav-link {
    font-size: 0.88rem;
    font-weight: 600;
    color: var(--mcf-charcoal);
    white-space: nowrap;
    transition: color 0.2s;
    background: none;
    border: none;
    cursor: pointer;
    font-family: var(--font-family);
    padding: 0;
  }
  .header__nav-link:hover { color: var(--mcf-primary); }

  /* Dropdown */
  .header__dropdown { position: relative; }

  .header__dropdown-trigger {
    display: inline-flex;
    align-items: center;
    gap: 0.15rem;
  }

  .header__dropdown-arrow {
    font-size: 1.1rem;
    transition: transform 0.2s;
  }

  .header__dropdown.open .header__dropdown-arrow {
    transform: rotate(180deg);
  }

  .header__dropdown-menu {
    display: none;
    position: absolute;
    top: calc(100% + 0.5rem);
    left: 50%;
    transform: translateX(-50%);
    background: #ffffff;
    border: 1px solid var(--color-border);
    border-radius: var(--radius);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.1);
    min-width: 220px;
    padding: 0.5rem 0;
    z-index: 200;
  }

  .header__dropdown.open .header__dropdown-menu { display: block; }

  .header__dropdown-item {
    display: block;
    padding: 0.6rem 1.25rem;
    font-size: 0.88rem;
    font-weight: 500;
    color: var(--mcf-charcoal);
    transition: background 0.15s, color 0.15s;
  }
  .header__dropdown-item:hover {
    background: var(--mcf-ghost);
    color: var(--mcf-primary);
  }

  /* CTA */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.55rem 1.25rem;
    border-radius: 8px;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s;
  }
  .header__cta:hover { transform: translateY(-1px); }

  .header__cta--accent {
    background: var(--mcf-primary);
    color: #ffffff;
  }
  .header__cta--accent:hover { background: var(--mcf-primary-dark); }

  /* Hamburger */
  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    flex-shrink: 0;
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--mcf-charcoal);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .header__hamburger.open .header__hamburger-line:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }
  .header__hamburger.open .header__hamburger-line:nth-child(2) { opacity: 0; }
  .header__hamburger.open .header__hamburger-line:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* Mobile menu */
  .header__mobile-menu {
    display: none;
    background: #ffffff;
    border-top: 1px solid var(--color-border);
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0;
  }

  .header__mobile-link {
    display: block;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--mcf-charcoal);
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s;
  }
  .header__mobile-link:hover { color: var(--mcf-primary); }

  /* Mobile servizi espandibili */
  .header__mobile-section {
    display: flex;
    align-items: center;
    justify-content: space-between;
    width: 100%;
    padding: 0.75rem 0;
    font-size: 1rem;
    font-weight: 700;
    color: var(--mcf-accent);
    background: none;
    border: none;
    border-bottom: 1px solid var(--color-border);
    cursor: pointer;
    font-family: var(--font-family);
  }
  .header__mobile-section .material-icons-outlined {
    font-size: 1.2rem;
    transition: transform 0.2s;
  }
  .header__mobile-section.open .material-icons-outlined {
    transform: rotate(180deg);
  }

  .header__mobile-sub {
    display: none;
    flex-direction: column;
    padding-left: 1rem;
  }
  .header__mobile-sub.open { display: flex; }

  .header__mobile-sublink {
    display: block;
    padding: 0.6rem 0;
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--mcf-charcoal);
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s;
  }
  .header__mobile-sublink:hover { color: var(--mcf-primary); }

  .header__mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }
  .header__mobile-actions .header__cta {
    justify-content: center;
    font-size: 0.95rem;
    padding: 0.75rem 1.25rem;
  }

  @media (max-width: 960px) {
    .header__nav, .header__actions { display: none; }
    .header__hamburger { display: flex; margin-left: auto; }
    .header__mobile-menu.open { display: block; }
  }
</style>
