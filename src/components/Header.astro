---
import { existsSync } from 'node:fs';
import { resolve } from 'node:path';

interface Props {
  minimal?: boolean;
}

const { minimal = false } = Astro.props;
const logoExists = existsSync(resolve('public/images/logo.png'));

const navLinks = [
  { label: 'Noleggio Operativo', href: '/noleggio-operativo' },
  { label: 'Leasing', href: '/leasing-strumentale' },
  { label: 'Finanziamenti', href: '/finanziamenti-pmi' },
  { label: 'Agevolazioni', href: '/noleggio-fotovoltaico-senza-burocrazia' },
];
---

<header class="header">
  <div class="header__inner">
    <a href="/" class="header__logo" aria-label="Mediocredito Facile — Home">
      {logoExists ? (
        <img src="/images/logo.png" alt="Mediocredito Facile" class="header__logo-img" />
      ) : (
        <span class="header__logo-text">MEDIOCREDITO<strong>FACILE</strong></span>
      )}
    </a>

    {minimal ? (
      <a href="tel:+393939957840" class="header__phone">
        <span class="material-icons-outlined" aria-hidden="true">phone</span>
        +39 393 995 7840
      </a>
    ) : (
      <>
        <nav class="header__nav" id="main-nav" aria-label="Navigazione principale">
          {navLinks.map((link) => (
            <a href={link.href} class="header__nav-link">{link.label}</a>
          ))}
        </nav>

        <div class="header__actions">
          <a href="/diventa-partner" class="header__cta header__cta--accent">Diventa Partner</a>
          <a href="/finanza-veloce" class="header__cta header__cta--outline">Finanzia il tuo Investimento</a>
        </div>

        <button class="header__hamburger" id="hamburger-btn" aria-label="Apri menu" aria-expanded="false" aria-controls="mobile-menu">
          <span class="header__hamburger-line"></span>
          <span class="header__hamburger-line"></span>
          <span class="header__hamburger-line"></span>
        </button>
      </>
    )}
  </div>

  {!minimal && (
    <div class="header__mobile-menu" id="mobile-menu" aria-hidden="true">
      <nav class="header__mobile-nav">
        {navLinks.map((link) => (
          <a href={link.href} class="header__mobile-link">{link.label}</a>
        ))}
        <div class="header__mobile-actions">
          <a href="/diventa-partner" class="header__cta header__cta--accent">Diventa Partner</a>
          <a href="/finanza-veloce" class="header__cta header__cta--outline">Finanzia il tuo Investimento</a>
        </div>
      </nav>
    </div>
  )}
</header>

<script>
  const btn = document.getElementById('hamburger-btn');
  const menu = document.getElementById('mobile-menu');

  btn?.addEventListener('click', () => {
    const expanded = btn.getAttribute('aria-expanded') === 'true';
    btn.setAttribute('aria-expanded', String(!expanded));
    btn.classList.toggle('open');
    menu?.classList.toggle('open');
    menu?.setAttribute('aria-hidden', String(expanded));
  });

  // Close menu when clicking a link
  menu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      btn?.setAttribute('aria-expanded', 'false');
      btn?.classList.remove('open');
      menu.classList.remove('open');
      menu.setAttribute('aria-hidden', 'true');
    });
  });
</script>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: rgba(255, 255, 255, 0.95);
    border-bottom: 1px solid var(--color-border);
    backdrop-filter: blur(8px);
  }

  .header__inner {
    max-width: var(--max-width);
    margin: 0 auto;
    padding: 0.75rem 1.5rem;
    display: flex;
    align-items: center;
    gap: 1.5rem;
  }

  /* Logo */
  .header__logo {
    flex-shrink: 0;
  }

  .header__logo-img {
    height: 36px;
    width: auto;
    display: block;
  }

  .header__logo-text {
    font-size: 1.15rem;
    color: var(--color-primary);
    letter-spacing: 0.04em;
    font-weight: 700;
    white-space: nowrap;
  }

  .header__logo-text strong {
    color: var(--color-accent);
    font-weight: 800;
  }

  /* Phone (minimal mode) */
  .header__phone {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    margin-left: auto;
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
    transition: color 0.2s;
  }

  .header__phone:hover {
    color: var(--color-accent);
  }

  .header__phone .material-icons-outlined {
    font-size: 1.2rem;
  }

  /* Nav links */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    flex: 1;
    justify-content: center;
  }

  .header__nav-link {
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-text);
    white-space: nowrap;
    transition: color 0.2s;
  }

  .header__nav-link:hover {
    color: var(--color-primary);
  }

  /* CTA buttons */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    flex-shrink: 0;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    font-size: 0.85rem;
    font-weight: 700;
    padding: 0.55rem 1.1rem;
    border-radius: 8px;
    white-space: nowrap;
    transition: background 0.2s, transform 0.15s, box-shadow 0.2s;
  }

  .header__cta:hover {
    transform: translateY(-1px);
  }

  .header__cta--accent {
    background: var(--color-accent);
    color: #ffffff;
  }

  .header__cta--accent:hover {
    background: var(--color-accent-hover);
  }

  .header__cta--outline {
    background: transparent;
    color: var(--color-primary);
    border: 2px solid var(--color-primary);
  }

  .header__cta--outline:hover {
    background: var(--color-primary-bg);
  }

  /* Hamburger */
  .header__hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 36px;
    height: 36px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 6px;
    flex-shrink: 0;
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2.5px;
    background: var(--color-primary);
    border-radius: 2px;
    transition: transform 0.3s, opacity 0.3s;
  }

  .header__hamburger.open .header__hamburger-line:nth-child(1) {
    transform: translateY(7.5px) rotate(45deg);
  }

  .header__hamburger.open .header__hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .header__hamburger.open .header__hamburger-line:nth-child(3) {
    transform: translateY(-7.5px) rotate(-45deg);
  }

  /* Mobile menu */
  .header__mobile-menu {
    display: none;
    background: #ffffff;
    border-top: 1px solid var(--color-border);
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    padding: 1rem 1.5rem 1.5rem;
    gap: 0.25rem;
  }

  .header__mobile-link {
    display: block;
    padding: 0.7rem 0;
    font-size: 1rem;
    font-weight: 600;
    color: var(--color-text);
    border-bottom: 1px solid var(--color-border);
    transition: color 0.2s;
  }

  .header__mobile-link:hover {
    color: var(--color-primary);
  }

  .header__mobile-actions {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-top: 1rem;
  }

  .header__mobile-actions .header__cta {
    justify-content: center;
    font-size: 0.95rem;
    padding: 0.75rem 1.25rem;
  }

  /* Responsive */
  @media (max-width: 960px) {
    .header__nav,
    .header__actions {
      display: none;
    }

    .header__hamburger {
      display: flex;
      margin-left: auto;
    }

    .header__mobile-menu.open {
      display: block;
    }
  }
</style>
